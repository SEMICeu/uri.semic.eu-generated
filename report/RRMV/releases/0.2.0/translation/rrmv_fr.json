        "fr": "Enter your translation here"
      }
    },
    {
      "EA-Guid": "{6865B7E8-3E3C-433e-BC24-68C71D8CDB99}",
      "name": "InstantTemportalEntitySpecification",
      "label": {
        "en": "Instant Temportal Entity Specification",
        "fr": "Enter your translation here"
      },
      "definition": {
        "en": "A set point in time, representing a single moment without duration. It can be used, for example, when a normative provision establishes a specific temporal reference, such as a deadline, start time, or activation moment. This class is appropriate for establishing unique temporal reference points for normative provisions and other use cases.",
        "fr": "Enter your translation here"
      }
    },
    {
      "EA-Guid": "{A56544C4-6C89-4e37-968A-8893007E78F8}",
      "name": "IntervalTemporalEntitySpecification",
      "label": {
        "en": "Interval Temporal Entity Specification",
        "fr": "Enter your translation here"
      },
      "definition": {
        "en": "A segment of time with determined start and end points, representing a period of time. This class is appropriate for modelling validity periods, time windows for regulatory compliance, and reporting cycles with defined temporal boundaries, among others.",
        "fr": "Enter your translation here"
      }
    },
