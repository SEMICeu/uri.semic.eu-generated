    {
      "@id": "http://data.europa.eu/eli/ontology#LegalExpression",
      "@type": "http://www.w3.org/2002/07/owl#Class",
      "EA-Guid": "{1FD788F9-6108-4793-83D6-B2EE43F86B0C}",
      "ap-definition-en": {
        "en": "The intellectual realisation of a legal resource in the form of a &quot;sequence of signs&quot; (typically alpha-numeric characters in a legal context).\nFor example, any version of the legal resource whose content is specified and different from others for any reason: language, versions, etc.;\n\nNote that ELI ontology accommodates different point of view on what should be considered a new legal resource, or a new legal expression of the same resource. Typically, a consolidated version can be viewed, in the context of ELI, either as separate legal resource (linked to original version and previous consolidated version using corresponding ELI relations), or as a different legal expression of the same legal resource."
      },
      "ap-label-en": {
        "en": "Legal Expression"
      },
      "definition": {
        "en": "The intellectual realisation of a legal resource in the form of a &quot;sequence of signs&quot; (typically alpha-numeric characters in a legal context).\nFor example, any version of the legal resource whose content is specified and different from others for any reason: language, versions, etc.;\n\nNote that ELI ontology accommodates different point of view on what should be considered a new legal resource, or a new legal expression of the same resource. Typically, a consolidated version can be viewed, in the context of ELI, either as separate legal resource (linked to original version and previous consolidated version using corresponding ELI relations), or as a different legal expression of the same legal resource."
      },
      "extra": {
        "EA-Guid": "{1FD788F9-6108-4793-83D6-B2EE43F86B0C}",
        "EA-Name": "LegalExpression",
        "EA-Package": "eli",
