    {
      "@id": "http://www.w3.org/ns/adms#identifier",
      "@type": "http://www.w3.org/2002/07/owl#ObjectProperty",
      "EA-Guid": "{2664E831-0FF3-4e7a-8630-095C79AC43F9}",
      "ap-definition-en": {
        "en": "The unambiguous structured reference for the Legal Entity, which is different from the one denoting its legal status."
      },
      "ap-label-en": {
        "en": "identifier"
      },
      "codelist": [],
      "definition": {
        "en": "The unambiguous structured reference for the Legal Entity, which is different from the one denoting its legal status."
      },
      "domain": [
        {
          "EA-Name": "LegalEntity",
          "uri": "http://www.w3.org/ns/legal#LegalEntity"
        }
      ],
      "extra": {
        "EA-Domain": "LegalEntity",
        "EA-Domain-Guid": "{FAFDAEBD-DC17-48ab-B8A3-B2311DA155BE}",
        "EA-Guid": "{2664E831-0FF3-4e7a-8630-095C79AC43F9}",
        "EA-Name": "identifier",
        "EA-Package": "Core Business",
        "EA-Range": "Identifier",
        "EA-Type": "attribute",
        "RangeData": {
          "EA-GUID": "{4252FD49-50E1-4fa8-AE37-1FE59010D3AB}",
          "EA-Name": "Identifier",
          "EA-Package": "adms",
          "uri": "http://www.w3.org/ns/adms#Identifier"
        },
        "RawTags": [
          {
            "key": "uri",
            "note": "null",
            "value": "http://www.w3.org/ns/adms#identifier"
          },
          {
            "key": "label-en",
            "note": "null",
            "value": "identifier"
          },
          {
            "key": "definition-en",
            "note": "null",
            "value": "The unambiguous structured reference for the Legal Entity, which is different from the one denoting its legal status."
          },
          {
            "key": "usageNote-en",
            "note": "Legal Entities may have any number of identifiers (but only one legal identifier). For example, in many jurisdictions, a business will have one or more tax numbers associated with them which do not, by themselves, confer legal entity status. An individual may be issued with identifiers for everything from social security to club membership. The identifier relationship must not be used to link to the identifier issued by the authority that conferred legal entity status on a business.",
            "value": "NOTE"
          }
        ],
        "Scope": "NOTHING",
