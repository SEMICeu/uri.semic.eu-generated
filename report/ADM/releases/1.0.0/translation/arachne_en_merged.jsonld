    {
      "@id": "http://www.w3.org/ns/adms#identifier",
      "@type": "http://www.w3.org/2002/07/owl#ObjectProperty",
      "EA-Guid": "{6810E12D-C741-4da7-B9EB-2B2AD14127BF}",
      "ap-definition-en": {
        "en": "The unambiguous structured reference for the Legal Entity, which is different from the one denoting its legal status."
      },
      "ap-label-en": {
        "en": "identifier"
      },
      "codelist": [],
      "definition": {
        "en": "The unambiguous structured reference for the Legal Entity, which is different from the one denoting its legal status."
      },
      "domain": [
        {
          "EA-Name": "LegalEntity",
          "uri": "http://www.w3.org/ns/legal#LegalEntity"
        }
      ],
      "extra": {
        "DestRoleTags": [
          {
            "key": "uri",
            "note": "http://www.w3.org/ns/adms#identifier",
            "value": "NOTE"
          },
          {
            "key": "label-en",
            "note": "identifier",
            "value": "NOTE"
          },
          {
            "key": "usageNote-en",
            "note": "NOTE$ea_notes=Legal Entities may have any number of identifiers (but only one legal identifier). For example, in many jurisdictions, a business will have one or more tax numbers associated with them which do not, by themselves, confer legal entity status. An individual may be issued with identifiers for everything from social security to club membership. The identifier relationship must not be used to link to the identifier issued by the authority that conferred legal entity status on a business.",
            "value": "NOTE"
          },
          {
            "key": "package",
            "note": "adms",
            "value": "NOTE"
          },
          {
            "key": "definition-en",
