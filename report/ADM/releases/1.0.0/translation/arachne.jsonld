    {
      "@id": "http://www.w3.org/ns/legal#legalIdentifier",
      "@type": "http://www.w3.org/2002/07/owl#ObjectProperty",
      "name": "legalIdentifier",
      "inpackage": "OTHER_PACKAGE",
      "ap-definition-en": {
        "en": "The unambiguous structured reference assigned to the Legal Entity by the legal authority that registered it."
      },
      "usage": {
        "en": "Legal Entity must have a unique identification number, allowing it to be clearly identified in communication across business registers.\r\n\r\nThe details of the registration are provided as properties of the Identifier class. The Core vocabulary sets no restriction on the type of legal identifier. In many countries, the business register's identifier is the relevant data point."
      },
      "ap-label-en": {
        "en": "legal identifier"
      },
