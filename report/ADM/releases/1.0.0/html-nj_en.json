    {
      "uri": "http://www.w3.org/2001/XMLSchema#date",
      "name": "Date",
      "label": {
        "en": "Date"
      },
      "sort": "Date",
      "description": {
        "en": "Date represents top-open intervals of exactly one day in length on the timelines of dateTime, beginning on the beginning moment of each day, up to but not including the beginning moment of the next day).  For non-timezoned values, the top-open intervals disjointly cover the non-timezoned timeline, one per day.  For timezoned values, the intervals begin at every minute and therefore overlap."
      },
      "usage": {},
      "parents": [],
      "rawTags": {
        "uri": "http://www.w3.org/2001/XMLSchema#date",
        "label-en": "Date",
        "definition-en": "Date represents top-open intervals of exactly one day in length on the timelines of dateTime, beginning on the beginning moment of each day, up to but not including the beginning moment of the next day).  For non-timezoned values, the top-open intervals disjointly cover the non-timezoned timeline, one per day.  For timezoned values, the intervals begin at every minute and therefore overlap."
      },
