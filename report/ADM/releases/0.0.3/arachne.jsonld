"@type": "http://www.w3.org/2002/07/owl#DatatypeProperty",
"name": "locatorDesignator",
"inpackage": "OTHER_PACKAGE",
"ap-definition-en" : {"en": "A number or sequence of characters that uniquely identifies the locator within the relevant scope."}, "usage" : {"en": "In simpler terms, this is the building number, apartment number, etc. For an address such as \"Flat 3, 17 Bridge Street\", the locator is \"flat 3, 17\"."}, "ap-label-en" : {"en": "locator designator"}, "definition" : {"en": "A number or sequence of characters that uniquely identifies the locator within the relevant scope."}, "label" : {"en": "locator designator"},
