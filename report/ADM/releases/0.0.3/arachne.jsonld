, {
"@id": "http://www.w3.org/2001/XMLSchema#date",
"@type": "http://www.w3.org/2002/07/owl#Class",
"inpackage": "OTHER_PACKAGE",
"ap-definition-en" : {"en": "Date represents top-open intervals of exactly one day in length on the timelines of dateTime, beginning on the beginning moment of each day, up to but not including the beginning moment of the next day).  For non-timezoned values, the top-open intervals disjointly cover the non-timezoned timeline, one per day.  For timezoned values, the intervals begin at every minute and therefore overlap."}, "ap-label-en" : {"en": "Date"}, "definition" : {"en": "Date represents top-open intervals of exactly one day in length on the timelines of dateTime, beginning on the beginning moment of each day, up to but not including the beginning moment of the next day).  For non-timezoned values, the top-open intervals disjointly cover the non-timezoned timeline, one per day.  For timezoned values, the intervals begin at every minute and therefore overlap."}, "label" : {"en": "Date"},
"extra": {"EA-Name" : "Date", "EA-Guid" : "{52D35956-7039-4b23-B88B-4605FF0ECCC9}", "EA-Package" : "DataTypes", "EA-Type" : "DATATYPE", "EA-Parents" : "", "EA-Parents2" : [], "parentclasses" : "", "label" : "Date", "definition" : "Date represents top-open intervals of exactly one day in length on the timelines of dateTime, beginning on the beginning moment of each day, up to but not including the beginning moment of the next day).  For non-timezoned values, the top-open intervals disjointly cover the non-timezoned timeline, one per day.  For timezoned values, the intervals begin at every minute and therefore overlap.", "usage" : "", "ap-label-en" : "Date", "ap-definition-en" : "Date represents top-open intervals of exactly one day in length on the timelines of dateTime, beginning on the beginning moment of each day, up to but not including the beginning moment of the next day).  For non-timezoned values, the top-open intervals disjointly cover the non-timezoned timeline, one per day.  For timezoned values, the intervals begin at every minute and therefore overlap.", "ap-usageNote-en" : "", "ap-codelist" : "", "RawTags" : [{ "key": "uri", "value": "http:\/\/www.w3.org\/2001\/XMLSchema#date", "note": "null" }, { "key": "label-en", "value": "Date", "note": "null" }, { "key": "definition-en", "value": "NOTE", "note": "Date represents top-open intervals of exactly one day in length on the timelines of dateTime, beginning on the beginning moment of each day, up to but not including the beginning moment of the next day).  For non-timezoned values, the top-open intervals disjointly cover the non-timezoned timeline, one per day.  For timezoned values, the intervals begin at every minute and therefore overlap." }], "Scope" : "NOTHING", "ap-definition-en" : {"en": "Date represents top-open intervals of exactly one day in length on the timelines of dateTime, beginning on the beginning moment of each day, up to but not including the beginning moment of the next day).  For non-timezoned values, the top-open intervals disjointly cover the non-timezoned timeline, one per day.  For timezoned values, the intervals begin at every minute and therefore overlap."}, "ap-label-en" : {"en": "Date"}, "definition" : {"en": "Date represents top-open intervals of exactly one day in length on the timelines of dateTime, beginning on the beginning moment of each day, up to but not including the beginning moment of the next day).  For non-timezoned values, the top-open intervals disjointly cover the non-timezoned timeline, one per day.  For timezoned values, the intervals begin at every minute and therefore overlap."}, "label" : {"en": "Date"}},
"name": "Date"
}
, {
"@id": "http://www.w3.org/2001/XMLSchema#dateTime",
"@type": "http://www.w3.org/2002/07/owl#Class",
"inpackage": "OTHER_PACKAGE",
"ap-definition-en" : {"en": "dateTime represents instants of time, optionally marked with a particular time zone offset.  Values representing the same instant but having different time zone offsets are equal but not identical."}, "ap-label-en" : {"en": "Date Time"}, "definition" : {"en": "dateTime represents instants of time, optionally marked with a particular time zone offset.  Values representing the same instant but having different time zone offsets are equal but not identical."}, "label" : {"en": "Date Time"},
