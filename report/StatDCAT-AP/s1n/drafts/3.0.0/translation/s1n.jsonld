        {
            "@id": "http://data.europa.eu/s1n/numSeries",
            "@type": "http://www.w3.org/2002/07/owl#DatatypeProperty",
            "name": "numberOfDataSeries",
            "inpackage": "ACTIVE_PACKAGE",
            "label-en": {
                "en": "number of data series"
            },
            "definition-en": {
                "en": "represents the number of distinct time series available in the dataset that contain data.\r\nA distinct time series is defined as a unique combination of dimension values (such as country, sex, age, unit of measure, etc.) that has at least one observation value or attribute associated with it - where an attribute may include a flag even in the absence of an actual data value. Time (e.g., year) is treated as one dimension among others, not as a unit of aggregation."
            },
            "definition": {
                "en": "represents the number of distinct time series available in the dataset that contain data.\r\nA distinct time series is defined as a unique combination of dimension values (such as country, sex, age, unit of measure, etc.) that has at least one observation value or attribute associated with it - where an attribute may include a flag even in the absence of an actual data value. Time (e.g., year) is treated as one dimension among others, not as a unit of aggregation."
            },
