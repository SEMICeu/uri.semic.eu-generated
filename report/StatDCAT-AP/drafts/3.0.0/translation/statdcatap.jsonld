        {
            "@id": "http://data.europa.eu/eli/ontology#LegalResource",
            "@type": "http://www.w3.org/2002/07/owl#Class",
            "inpackage": "OTHER_PACKAGE",
            "ap-definition-en": {
                "en": "This class represents the legislation, policy or policies that lie behind the Rules that govern the service."
            },
            "ap-usageNote-en": {
                "en": "The definition and properties of the Legal Resource class are aligned with the ontology included in \"Council conclusions inviting the introduction of the European Legislation Identifier (ELI)\". For describing the attributes of a Legal Resource (labels, preferred labels, alternative labels, definition, etc.) we refer to the ELI ontology.\r\n\r\nIn this data specification the use is restricted to instances of this class that follow the ELI URI guidelines."
            },
            "usage": {
                "en": "The definition and properties of the Legal Resource class are aligned with the ontology included in \"Council conclusions inviting the introduction of the European Legislation Identifier (ELI)\". For describing the attributes of a Legal Resource (labels, preferred labels, alternative labels, definition, etc.) we refer to the ELI ontology.\r\n\r\nIn this data specification the use is restricted to instances of this class that follow the ELI URI guidelines."
            },
            "ap-label-en": {
                "en": "Legal Resource"
            },
            "definition": {
                "en": "This class represents the legislation, policy or policies that lie behind the Rules that govern the service."
            },
