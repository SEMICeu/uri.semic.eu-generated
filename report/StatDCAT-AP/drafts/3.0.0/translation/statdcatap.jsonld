        {
            "@id": "http://xmlns.com/foaf/0.1/primaryTopic",
            "@type": "http://www.w3.org/2002/07/owl#ObjectProperty",
            "name": "primaryTopic",
            "inpackage": "ACTIVE_PACKAGE",
            "ap-definition-en": {
                "en": "A link to the Dataset, Data service or Catalog described in the record."
            },
            "ap-usageNote-en": {
                "en": "A catalogue record will refer to one entity in a catalogue. This can be either a Dataset or a Data Service. To ensure an unambigous reading of the cardinality the range is set to Catalogued Resource. However it is not the intend with this range to require the explicit use of the class Catalogued Record. As abstract class, an subclass should be used."
            },
