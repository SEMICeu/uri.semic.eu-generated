    {
      "@id": "http://www.w3.org/ns/prov#endedAtTime",
      "@type": "http://www.w3.org/2002/07/owl#DatatypeProperty",
      "name": "endedAtTime",
      "inpackage": "OTHER_PACKAGE",
      "ap-definition-en": {
        "en": "End is when an activity is deemed to have been ended by an entity, known as trigger. The activity no longer exists after its end. Any usage, generation, or invalidation involving an activity precedes the activity's end. An end may refer to a trigger entity that terminated the activity, or to an activity, known as ender that generated the trigger."
      },
      "ap-label-en": {
        "en": "ended at time"
