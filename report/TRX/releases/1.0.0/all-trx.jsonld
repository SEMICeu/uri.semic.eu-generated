      "@id": "https://data.europa.eu/m8g/transform-validate-ontology#Transformation",
      "@type": "http://www.w3.org/2002/07/owl#Class",
      "ap-definition-en": {
        "en": "A planned set of operations intended by one or more agents aiming at converting an input data distribution into an output data distribution conforming to a given set of rules."
