    {
      "@id": "https://data.europa.eu/m8g/transform-validate-ontology#TransformationExecution",
      "@type": "http://www.w3.org/2002/07/owl#Class",
      "ap-definition-en": {
        "en": "It is an activity that carries out a transformation over a period of time actually converting the data of the transformation input source distribution into data then included in a output distribution. It inherits the prov:startedAtTime and prov:endedAtTime properties of the class prov:Activity in order to specify when the activity started and ended."
      },
      "ap-label-en": {
        "en": "TransformationExecution"
      },
      "definition": {
