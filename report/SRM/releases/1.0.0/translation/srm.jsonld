    {
      "@id": "https://www.w3.org/2001/XMLSchema#dateTime",
      "@type": "http://www.w3.org/2002/07/owl#Class",
      "inpackage": "OTHER_PACKAGE",
      "ap-definition-en": {
        "en": "DateTime values may be viewed as objects with integer-valued year, month, day, hour and minute properties, a decimal-valued second property, and a boolean timezoned property."
      },
      "ap-label-en": {
        "en": "DateTime"
      },
