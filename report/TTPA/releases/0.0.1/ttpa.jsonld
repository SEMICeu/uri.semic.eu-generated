"ap-definition-en" : {"en": "Information about the financial resources used for the political advertisement or campaign."}, "usage" : {"en": "Links the Transparency Notice to the funding information for the political advertisement and, where applicable, the political advertising campaign. Aggregated amounts, values of in-kind benefits, their public\/private and EU\/non-EU origin, and the calculation methodology must be provided."}, "ap-label-en" : {"en": "has funding"}, "definition" : {"en": "Information about the financial resources used for the political advertisement or campaign."}, "label" : {"en": "has funding"},
