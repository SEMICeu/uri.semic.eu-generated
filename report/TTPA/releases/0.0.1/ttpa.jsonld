"@id": "http://example.org/calculationMethodology",
"@type": "http://www.w3.org/2002/07/owl#DatatypeProperty",
"name": "calculationMethodology",
"inpackage": "OTHER_PACKAGE",
"ap-definition-en" : {"en": "The method or approach used to calculate the amount or allocation of funding."}, "usage" : {"en": "Describe the methodology used to calculate the aggregated amounts and value of other benefits received by the providers of political advertising services, including whether the figures reflect invoiced, budgeted, and\/or charged amounts and whether VAT is included. For in-kind benefits, indicate the valuation method used."}, "ap-label-en" : {"en": "calculation methodology"}, "definition" : {"en": "The method or approach used to calculate the amount or allocation of funding."}, "label" : {"en": "calculation methodology"},
"extra": {"EA-Name" : "calculationMethodology", "EA-Guid" : "{3BF0C1F0-FFE8-4179-949E-70EF882AF33E}", "EA-Package" : "TTPAV", "EA-Type" : "attribute", "EA-Domain" : "Funding ", "EA-Domain-Guid" : "{2BA925B9-DE4D-4e55-898D-A44127DD0971}", "EA-Range" : "Text", "RangeData" : {"EA-Name" : "Text", "EA-GUID" : "{31427F3B-588A-40dd-968A-ED4472D160DC}", "EA-Package" : "datatypes", "uri" : "http://www.w3.org/1999/02/22-rdf-syntax-ns#langString" }, "label" : "calculation methodology", "definition" : "The method or approach used to calculate the amount or allocation of funding.", "usage" : "Describe the methodology used to calculate the aggregated amounts and value of other benefits received by the providers of political advertising services, including whether the figures reflect invoiced, budgeted, and\/or charged amounts and whether VAT is included. For in-kind benefits, indicate the valuation method used.", "ap-label-en" : "calculation methodology", "ap-definition-en" : "The method or approach used to calculate the amount or allocation of funding.", "ap-usageNote-en" : "", "ap-codelist" : "", "RawTags" : [{ "key": "label-en", "value": "calculation methodology", "note": "null" }, { "key": "definition-en", "value": "The method or approach used to calculate the amount or allocation of funding.", "note": "null" }, { "key": "uri", "value": "http:\/\/example.org\/calculationMethodology", "note": "null" }, { "key": "usageNote-en", "value": "NOTE", "note": "Describe the methodology used to calculate the aggregated amounts and value of other benefits received by the providers of political advertising services, including whether the figures reflect invoiced, budgeted, and\/or charged amounts and whether VAT is included. For in-kind benefits, indicate the valuation method used." }, { "key": "REF", "value": "Reg. (EU) 2024\/900, Art. 12(1)(f); Impl. Reg. (EU) 2025\/1410, Annex II, \u00A73.8", "note": "null" }], "Scope" : "TRANSLATIONS_ONLY", "ap-definition-en" : {"en": "The method or approach used to calculate the amount or allocation of funding."}, "usage" : {"en": "Describe the methodology used to calculate the aggregated amounts and value of other benefits received by the providers of political advertising services, including whether the figures reflect invoiced, budgeted, and\/or charged amounts and whether VAT is included. For in-kind benefits, indicate the valuation method used."}, "ap-label-en" : {"en": "calculation methodology"}, "definition" : {"en": "The method or approach used to calculate the amount or allocation of funding."}, "label" : {"en": "calculation methodology"}},
