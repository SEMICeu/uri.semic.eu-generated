, {
"@id": "http://data.europa.eu/m8g/registeredAddress",
"@type": "http://www.w3.org/2002/07/owl#ObjectProperty",
"name": "registeredAddress",
"inpackage": "ACTIVE_PACKAGE",
"ap-definition-en" : {"en": "The registered address relationship links a Resource with the legally registered Address."}, "usage" : {"en": "Links an Agent to its legally registered address, i.e. the address of its place of establishment. Use for organisations to record their official registered location."}, "ap-label-en" : {"en": "registered address"}, "definition" : {"en": "The registered address relationship links a Resource with the legally registered Address."}, "label" : {"en": "registered address"},
