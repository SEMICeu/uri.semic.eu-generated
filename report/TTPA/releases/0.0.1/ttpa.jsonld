, {
"@id": "http://www.w3.org/ns/legal#LegalEntity",
"@type": "http://www.w3.org/2002/07/owl#Class",
"inpackage": "OTHER_PACKAGE",
"ap-definition-en" : {"en": "A self-employed person,company,or organization that has legal rights and obligations."}, "usage" : {"en": "Use this class to represent any legal entity involved in the context of a political advertisement, including the sponsor, the paying entity, or the entity ultimately controlling the sponsor. Required identity fields include business name, legal name, email address, place of establishment, and, where applicable, registration number."}, "ap-label-en" : {"en": "Legal Entity"}, "definition" : {"en": "A self-employed person,company,or organization that has legal rights and obligations."}, "label" : {"en": "Legal Entity"},
"extra": {"EA-Name" : "LegalEntity", "EA-Guid" : "{D7465C4B-0B62-41dc-808A-8F0E04B79276}", "EA-Package" : "TTPAV", "EA-Type" : "CLASS", "EA-Parents" : "Agent", "EA-Parents2" : [{ "name": "Agent", "label" : "Agent", "package" : "TTPAV", "uri" : "http://xmlns.com/foaf/0.1/Agent" }], "parentclasses" : "http://xmlns.com/foaf/0.1/Agent", "label" : "Legal Entity", "definition" : "A self-employed person,company,or organization that has legal rights and obligations.", "usage" : "Use this class to represent any legal entity involved in the context of a political advertisement, including the sponsor, the paying entity, or the entity ultimately controlling the sponsor. Required identity fields include business name, legal name, email address, place of establishment, and, where applicable, registration number.", "ap-label-en" : "Legal Entity", "ap-definition-en" : "A self-employed person,company,or organization that has legal rights and obligations.", "ap-usageNote-en" : "", "ap-codelist" : "", "RawTags" : [{ "key": "definition-en", "value": "A self-employed person,company,or organization that has legal rights and obligations.", "note": "A legal entity able to transact business, typically registered with a body able to confer legal status such as a national business register.\r\nIn RDF terms, a legal entity is a sub class of dcterms:Agent and foaf:Agent.\r\nIn XML terms, this is equivalent to the UN\/CEFACT term 'Business profile" }, { "key": "label-en", "value": "Legal Entity", "note": "null" }, { "key": "parentURI", "value": "http:\/\/www.w3.org\/ns\/org#FormalOrganization", "note": "null" }, { "key": "uri", "value": "http:\/\/www.w3.org\/ns\/legal#LegalEntity", "note": "null" }, { "key": "usageNote-en", "value": "NOTE", "note": "Use this class to represent any legal entity involved in the context of a political advertisement, including the sponsor, the paying entity, or the entity ultimately controlling the sponsor. Required identity fields include business name, legal name, email address, place of establishment, and, where applicable, registration number." }, { "key": "REF", "value": "Reg. (EU) 2024\/900, Art. 12(1)(a); Impl. Reg. (EU) 2025\/1410, Annex II, \u00A73.1", "note": "null" }], "Scope" : "TRANSLATIONS_ONLY", "ap-definition-en" : {"en": "A self-employed person,company,or organization that has legal rights and obligations."}, "usage" : {"en": "Use this class to represent any legal entity involved in the context of a political advertisement, including the sponsor, the paying entity, or the entity ultimately controlling the sponsor. Required identity fields include business name, legal name, email address, place of establishment, and, where applicable, registration number."}, "ap-label-en" : {"en": "Legal Entity"}, "definition" : {"en": "A self-employed person,company,or organization that has legal rights and obligations."}, "label" : {"en": "Legal Entity"}},
"name": "LegalEntity"
}
