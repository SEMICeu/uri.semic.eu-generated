, {
"@id": "http://example.org/retentionDeadline",
"@type": "http://www.w3.org/2002/07/owl#DatatypeProperty",
"name": "retentionDeadline",
"inpackage": "OTHER_PACKAGE",
"ap-definition-en" : {"en": "The date after which a resource or record is no longer required to be retained."}, "usage" : {"en": "Indicates the final date by which the transparency notice and any modifications must be retained. The retention period is seven years after the last publication of the related political advertisement. Calculate as: date of last publication + 7 years."}, "ap-label-en" : {"en": "retention deadline"}, "definition" : {"en": "The date after which a resource or record is no longer required to be retained."}, "label" : {"en": "retention deadline"},
"extra": {"EA-Name" : "retentionDeadline", "EA-Guid" : "{E9323274-77BF-48da-BEBC-0CD6E6D85000}", "EA-Package" : "TTPAV", "EA-Type" : "attribute", "EA-Domain" : "TransparencyNotice", "EA-Domain-Guid" : "{BA51F248-523B-418c-9F76-1672AF9FE56C}", "EA-Range" : "Date", "RangeData" : {"EA-Name" : "Date", "EA-Package" : "", "uri" : "http://www.w3.org/2001/XMLSchema#date" }, "label" : "retention deadline", "definition" : "The date after which a resource or record is no longer required to be retained.", "usage" : "Indicates the final date by which the transparency notice and any modifications must be retained. The retention period is seven years after the last publication of the related political advertisement. Calculate as: date of last publication + 7 years.", "ap-label-en" : "retention deadline", "ap-definition-en" : "The date after which a resource or record is no longer required to be retained.", "ap-usageNote-en" : "", "ap-codelist" : "", "RawTags" : [{ "key": "label-en", "value": "retention deadline", "note": "null" }, { "key": "definition-en", "value": "The date after which a resource or record is no longer required to be retained.", "note": "null" }, { "key": "uri", "value": "http:\/\/example.org\/retentionDeadline", "note": "null" }, { "key": "usageNote-en", "value": "Indicates the final date by which the transparency notice and any modifications must be retained. The retention period is seven years after the last publication of the related political advertisement. Calculate as: date of last publication + 7 years.", "note": "Indicates the final date by which the transparency notice and any modifications must be retained, in accordance with applicable legal, regulatory, or organisational requirements. For political advertising transparency notices under Regulation (EU) 2024\/900, this is at least seven years after the last publication of the related political advertisement. The value should be calculated as the date of last publication plus the required retention period (e.g., 7 years)." }, { "key": "REF", "value": "Reg. (EU) 2024\/900, Art. 12(4)", "note": "null" }], "Scope" : "TRANSLATIONS_ONLY", "ap-definition-en" : {"en": "The date after which a resource or record is no longer required to be retained."}, "usage" : {"en": "Indicates the final date by which the transparency notice and any modifications must be retained. The retention period is seven years after the last publication of the related political advertisement. Calculate as: date of last publication + 7 years."}, "ap-label-en" : {"en": "retention deadline"}, "definition" : {"en": "The date after which a resource or record is no longer required to be retained."}, "label" : {"en": "retention deadline"}},
