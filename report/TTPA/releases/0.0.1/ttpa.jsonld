"@type": "http://www.w3.org/2002/07/owl#ObjectProperty",
"name": "hasTime",
"inpackage": "OTHER_PACKAGE",
"ap-definition-en" : {"en": "\tThe association of a temporal entity (instant or interval) to any thing."}, "usage" : {"en": "Provide the date or date range of the public event. For elections and referendums, this corresponds to the official date(s) of the vote."}, "ap-label-en" : {"en": "has time"}, "definition" : {"en": "\tThe association of a temporal entity (instant or interval) to any thing."}, "label" : {"en": "has time"},
"extra": {"EA-Name" : "hasTime", "EA-Guid" : "{2AD827C3-6FE6-49db-BFB1-9E0D189CC8F3}", "EA-Package" : "TTPAV", "EA-Type" : "attribute", "EA-Domain" : "PublicEvent", "EA-Domain-Guid" : "{2F839BE3-F0A5-4456-AD5C-CECF4E7834C2}", "EA-Range" : "Temporal Entity", "RangeData" : {"EA-Name" : "Temporal Entity", "EA-GUID" : "{828F9DAC-FCAC-4daa-A22D-E1D2781141A8}", "EA-Package" : "datatypes", "uri" : "http://www.w3.org/2006/time#TemporalEntity" }, "label" : "has time", "definition" : "\tThe association of a temporal entity (instant or interval) to any thing.", "usage" : "Provide the date or date range of the public event. For elections and referendums, this corresponds to the official date(s) of the vote.", "ap-label-en" : "has time", "ap-definition-en" : "\tThe association of a temporal entity (instant or interval) to any thing.", "ap-usageNote-en" : "", "ap-codelist" : "", "RawTags" : [{ "key": "usageNote-en", "value": "Provide the date or date range of the public event. For elections and referendums, this corresponds to the official date(s) of the vote.", "note": "Provide the temporal instant or interval associated with the public event. For elections and referendums, this should correspond to the date(s) of the event as required by Article 12(1)(g) of Regulation (EU) 2024\/900 and Annex II, Template 3, point 9 of Implementing Regulation (EU) 2025\/1410." }, { "key": "uri", "value": "http:\/\/www.w3.org\/2006\/time#hasTime", "note": "null" }, { "key": "definition-en", "value": "\tThe association of a temporal entity (instant or interval) to any thing.", "note": "null" }, { "key": "label-en", "value": "has time", "note": "null" }, { "key": "REF", "value": "Reg. (EU) 2024\/900, Art. 12(1)(g); Impl. Reg. (EU) 2025\/1410, Annex II, \u00A73.9", "note": "null" }], "Scope" : "TRANSLATIONS_ONLY", "ap-definition-en" : {"en": "\tThe association of a temporal entity (instant or interval) to any thing."}, "usage" : {"en": "Provide the date or date range of the public event. For elections and referendums, this corresponds to the official date(s) of the vote."}, "ap-label-en" : {"en": "has time"}, "definition" : {"en": "\tThe association of a temporal entity (instant or interval) to any thing."}, "label" : {"en": "has time"}},
