, {
"@id": "http://xmlns.com/foaf/0.1/Agent",
"@type": "http://www.w3.org/2002/07/owl#Class",
"inpackage": "OTHER_PACKAGE",
"ap-definition-en" : {"en": "Entity that is able to carry out action."}, "usage" : {"en": "Use this class to represent any natural or legal person acting as a sponsor, paying entity, or controlling entity in the context of political advertising. It is the common superclass of Person and LegalEntity."}, "ap-label-en" : {"en": "Agent"}, "definition" : {"en": "Entity that is able to carry out action."}, "label" : {"en": "Agent"},
"extra": {"EA-Name" : "Agent", "EA-Guid" : "{B5AFAD81-D412-4384-895E-D16C345018FF}", "EA-Package" : "TTPAV", "EA-Type" : "CLASS", "EA-Parents" : "", "EA-Parents2" : [], "parentclasses" : "", "label" : "Agent", "definition" : "Entity that is able to carry out action.", "usage" : "Use this class to represent any natural or legal person acting as a sponsor, paying entity, or controlling entity in the context of political advertising. It is the common superclass of Person and LegalEntity.", "ap-label-en" : "Agent", "ap-definition-en" : "Entity that is able to carry out action.", "ap-usageNote-en" : "", "ap-codelist" : "", "RawTags" : [{ "key": "definition-en", "value": "Entity that is able to carry out action.", "note": "null" }, { "key": "label-en", "value": "Agent", "note": "null" }, { "key": "uri", "value": "http:\/\/xmlns.com\/foaf\/0.1\/Agent", "note": "null" }, { "key": "usageNote-en", "value": "Use this class to represent any natural or legal person acting as a sponsor, paying entity, or controlling entity in the context of political advertising. It is the common superclass of Person and LegalEntity.", "note": "In compliance with the description from <a href=\"http:\/\/xmlns.com\/foaf\/spec\/\">FOAF<\/a>, an Agent is considered as any entity that is able to carry out actions. The Agent class acts as a generic element which can be further specified by implementers for their usages, for example by defining the Person class from <a href=\"https:\/\/github.com\/SEMICeu\/Core-Person-Vocabulary\">the Core Person Vocabulary<\/a> or Organization from <a href=\"https:\/\/www.w3.org\/TR\/vocab-org\/\">W3C's Organization Ontology<\/a> as a subclasses of Agent. This Person or Organization can then issue a certain Requirement or be concerned by an Evidence provided." }, { "key": "REF", "value": "Reg. (EU) 2024\/900, Art. 12(1)(a); Art. 12(1)(b)", "note": "null" }], "Scope" : "TRANSLATIONS_ONLY", "ap-definition-en" : {"en": "Entity that is able to carry out action."}, "usage" : {"en": "Use this class to represent any natural or legal person acting as a sponsor, paying entity, or controlling entity in the context of political advertising. It is the common superclass of Person and LegalEntity."}, "ap-label-en" : {"en": "Agent"}, "definition" : {"en": "Entity that is able to carry out action."}, "label" : {"en": "Agent"}},
"name": "Agent"
}
