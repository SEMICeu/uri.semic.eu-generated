, {
"@id": "http://example.org/useOfAiSystems",
"@type": "http://www.w3.org/2002/07/owl#DatatypeProperty",
"name": "usageOfAiSystems",
"inpackage": "OTHER_PACKAGE",
"ap-definition-en" : {"en": "Indicates whether an artificial intelligence system was used in the targeting or delivery of a resource to an audience, including a description of its role and functioning."}, "usage" : {"en": "Indicate whether artificial intelligence systems were used in the targeting or ad-delivery of the political advertisement. Include a meaningful description of the AI system and its role."}, "ap-label-en" : {"en": "usage of AI systems"}, "definition" : {"en": "Indicates whether an artificial intelligence system was used in the targeting or delivery of a resource to an audience, including a description of its role and functioning."}, "label" : {"en": "usage of AI systems"},
"extra": {"EA-Name" : "useOfAiSystems", "EA-Guid" : "{6536B0F1-6FF3-4de5-B437-CE751E7E42FB}", "EA-Package" : "TTPAV", "EA-Type" : "attribute", "EA-Domain" : "Targeting", "EA-Domain-Guid" : "{8161C202-FCF7-4553-9B5D-6C18BA75F5A9}", "EA-Range" : "Text", "RangeData" : {"EA-Name" : "Text", "EA-GUID" : "{31427F3B-588A-40dd-968A-ED4472D160DC}", "EA-Package" : "datatypes", "uri" : "http://www.w3.org/1999/02/22-rdf-syntax-ns#langString" }, "label" : "usage of AI systems", "definition" : "Indicates whether an artificial intelligence system was used in the targeting or delivery of a resource to an audience, including a description of its role and functioning.", "usage" : "Indicate whether artificial intelligence systems were used in the targeting or ad-delivery of the political advertisement. Include a meaningful description of the AI system and its role.", "ap-label-en" : "usage of AI systems", "ap-definition-en" : "Indicates whether an artificial intelligence system was used in the targeting or delivery of a resource to an audience, including a description of its role and functioning.", "ap-usageNote-en" : "", "ap-codelist" : "", "RawTags" : [{ "key": "label-en", "value": "usage of AI systems", "note": "null" }, { "key": "definition-en", "value": "Indicates whether an artificial intelligence system was used in the targeting or delivery of a resource to an audience, including a description of its role and functioning.", "note": "null" }, { "key": "uri", "value": "http:\/\/example.org\/useOfAiSystems", "note": "null" }, { "key": "usageNote-en", "value": "Indicate whether artificial intelligence systems were used in the targeting or ad-delivery of the political advertisement. Include a meaningful description of the AI system and its role.", "note": "Indicate whether and how artificial intelligence systems were used in the targeting or ad-delivery of the political advertisement. Include a meaningful description of the AI system and its role, as required by Article 19(1)(c)(iv) of Regulation (EU) 2024\/900 and Annex II, Template 3, point 15(e) of Implementing Regulation (EU) 2025\/1410." }, { "key": "REF", "value": "Reg. (EU) 2024\/900, Art. 19(1)(c)(iv); Impl. Reg. (EU) 2025\/1410, Annex II, \u00A73.15(e)", "note": "null" }], "Scope" : "TRANSLATIONS_ONLY", "ap-definition-en" : {"en": "Indicates whether an artificial intelligence system was used in the targeting or delivery of a resource to an audience, including a description of its role and functioning."}, "usage" : {"en": "Indicate whether artificial intelligence systems were used in the targeting or ad-delivery of the political advertisement. Include a meaningful description of the AI system and its role."}, "ap-label-en" : {"en": "usage of AI systems"}, "definition" : {"en": "Indicates whether an artificial intelligence system was used in the targeting or delivery of a resource to an audience, including a description of its role and functioning."}, "label" : {"en": "usage of AI systems"}},
