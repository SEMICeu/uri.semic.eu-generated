, {
"@id": "http://example.org/useOfAnalyticalTechniques",
"@type": "http://www.w3.org/2002/07/owl#DatatypeProperty",
"name": "useOfAnalyticalTechniques",
"inpackage": "OTHER_PACKAGE",
"ap-definition-en" : {"en": "A short description of the analytical techniques used for targeting or ad-delivery of the political advertisement, including any use of artificial intelligence or automated systems."}, "usage" : {"en": "Provide a short description of the analytical techniques used for targeting or ad-delivery of the political advertisement. Examples include: audience segmentation (e.g., grouping users by age, location, or interests),\r\nprofiling (e.g., building user profiles based on online behavior),\r\nlookalike modeling (e.g., identifying users similar to an existing audience),\r\npredictive analytics (e.g., forecasting likelihood to engage or vote),\r\nA\/B testing (e.g., comparing ad variants to optimize performance),\r\nsentiment analysis (e.g., analyzing user comments or reactions),\r\nuse of artificial intelligence or machine learning algorithms (e.g., automated decision-making for ad placement or targeting)."}, "ap-label-en" : {"en": "use of analytical techniques"}, "definition" : {"en": "A short description of the analytical techniques used for targeting or ad-delivery of the political advertisement, including any use of artificial intelligence or automated systems."}, "label" : {"en": "use of analytical techniques"},
"extra": {"EA-Name" : "useOfAnalyticalTechniques", "EA-Guid" : "{9BD26626-2E54-49ee-9155-6EE487D3D09A}", "EA-Package" : "TTPAV", "EA-Type" : "attribute", "EA-Domain" : "Targeting", "EA-Domain-Guid" : "{8161C202-FCF7-4553-9B5D-6C18BA75F5A9}", "EA-Range" : "Text", "RangeData" : {"EA-Name" : "Text", "EA-GUID" : "{31427F3B-588A-40dd-968A-ED4472D160DC}", "EA-Package" : "datatypes", "uri" : "http://www.w3.org/1999/02/22-rdf-syntax-ns#langString" }, "label" : "use of analytical techniques", "definition" : "A short description of the analytical techniques used for targeting or ad-delivery of the political advertisement, including any use of artificial intelligence or automated systems.", "usage" : "Provide a short description of the analytical techniques used for targeting or ad-delivery of the political advertisement. Examples include: audience segmentation (e.g., grouping users by age, location, or interests),\r\nprofiling (e.g., building user profiles based on online behavior),\r\nlookalike modeling (e.g., identifying users similar to an existing audience),\r\npredictive analytics (e.g., forecasting likelihood to engage or vote),\r\nA\/B testing (e.g., comparing ad variants to optimize performance),\r\nsentiment analysis (e.g., analyzing user comments or reactions),\r\nuse of artificial intelligence or machine learning algorithms (e.g., automated decision-making for ad placement or targeting).", "ap-label-en" : "use of analytical techniques", "ap-definition-en" : "A short description of the analytical techniques used for targeting or ad-delivery of the political advertisement, including any use of artificial intelligence or automated systems.", "ap-usageNote-en" : "", "ap-codelist" : "", "RawTags" : [{ "key": "label-en", "value": "use of analytical techniques", "note": "null" }, { "key": "definition-en", "value": "A short description of the analytical techniques used for targeting or ad-delivery of the political advertisement, including any use of artificial intelligence or automated systems.", "note": "null" }, { "key": "uri", "value": "http:\/\/example.org\/useOfAnalyticalTechniques", "note": "null" }, { "key": "usageNote-en", "value": "NOTE", "note": "Provide a short description of the analytical techniques used for targeting or ad-delivery of the political advertisement. Examples include: audience segmentation (e.g., grouping users by age, location, or interests),\r\nprofiling (e.g., building user profiles based on online behavior),\r\nlookalike modeling (e.g., identifying users similar to an existing audience),\r\npredictive analytics (e.g., forecasting likelihood to engage or vote),\r\nA\/B testing (e.g., comparing ad variants to optimize performance),\r\nsentiment analysis (e.g., analyzing user comments or reactions),\r\nuse of artificial intelligence or machine learning algorithms (e.g., automated decision-making for ad placement or targeting)." }, { "key": "REF", "value": "Reg. (EU) 2024\/900, Art. 19(1)(c); Impl. Reg. (EU) 2025\/1410, Annex II, \u00A73.15(a)", "note": "null" }], "Scope" : "TRANSLATIONS_ONLY", "ap-definition-en" : {"en": "A short description of the analytical techniques used for targeting or ad-delivery of the political advertisement, including any use of artificial intelligence or automated systems."}, "usage" : {"en": "Provide a short description of the analytical techniques used for targeting or ad-delivery of the political advertisement. Examples include: audience segmentation (e.g., grouping users by age, location, or interests),\r\nprofiling (e.g., building user profiles based on online behavior),\r\nlookalike modeling (e.g., identifying users similar to an existing audience),\r\npredictive analytics (e.g., forecasting likelihood to engage or vote),\r\nA\/B testing (e.g., comparing ad variants to optimize performance),\r\nsentiment analysis (e.g., analyzing user comments or reactions),\r\nuse of artificial intelligence or machine learning algorithms (e.g., automated decision-making for ad placement or targeting)."}, "ap-label-en" : {"en": "use of analytical techniques"}, "definition" : {"en": "A short description of the analytical techniques used for targeting or ad-delivery of the political advertisement, including any use of artificial intelligence or automated systems."}, "label" : {"en": "use of analytical techniques"}},
