"inpackage": "OTHER_PACKAGE",
"ap-definition-en" : {"en": "Proper noun(s) applied to the real world entity identified by the locator. The locator name could be the name of the property or complex, of the building or part of the building, or it could be the name of a room inside a building."}, "usage" : {"en": "The locator name could be the name of the property or complex, of the building or part of the building, or it could be the name of a room inside a building."}, "ap-label-en" : {"en": "locator name"}, "definition" : {"en": "Proper noun(s) applied to the real world entity identified by the locator. The locator name could be the name of the property or complex, of the building or part of the building, or it could be the name of a room inside a building."}, "label" : {"en": "locator name"},
