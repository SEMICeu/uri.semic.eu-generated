{
"@id": "http://data.europa.eu/m8g/PublicEvent",
"@type": "http://www.w3.org/2002/07/owl#Class",
"inpackage": "OTHER_PACKAGE",
"ap-definition-en" : {"en": "Something that happens at a particular place and time, organised by one or more agents for a particular purpose, and is of interest to a general audience. This definition excludes natural events such as earthquakes and volcanic eruptions."}, "usage" : {"en": "Use this class as the common superclass for ElectionEvent. It represents an event that happens at a particular place and time and is of interest to a general audience. In the political advertising context, use it to describe elections or referendums to which a political advertisement may be linked."}, "ap-label-en" : {"en": "Public Event"}, "definition" : {"en": "Something that happens at a particular place and time, organised by one or more agents for a particular purpose, and is of interest to a general audience. This definition excludes natural events such as earthquakes and volcanic eruptions."}, "label" : {"en": "Public Event"},
"extra": {"EA-Name" : "PublicEvent", "EA-Guid" : "{2F839BE3-F0A5-4456-AD5C-CECF4E7834C2}", "EA-Package" : "TTPAV", "EA-Type" : "CLASS", "EA-Parents" : "", "EA-Parents2" : [], "parentclasses" : "", "label" : "Public Event", "definition" : "Something that happens at a particular place and time, organised by one or more agents for a particular purpose, and is of interest to a general audience. This definition excludes natural events such as earthquakes and volcanic eruptions.", "usage" : "Use this class as the common superclass for ElectionEvent. It represents an event that happens at a particular place and time and is of interest to a general audience. In the political advertising context, use it to describe elections or referendums to which a political advertisement may be linked.", "ap-label-en" : "Public Event", "ap-definition-en" : "Something that happens at a particular place and time, organised by one or more agents for a particular purpose, and is of interest to a general audience. This definition excludes natural events such as earthquakes and volcanic eruptions.", "ap-usageNote-en" : "", "ap-codelist" : "", "RawTags" : [{ "key": "usageNote-en", "value": "NOTE", "note": "Use this class as the common superclass for ElectionEvent. It represents an event that happens at a particular place and time and is of interest to a general audience. In the political advertising context, use it to describe elections or referendums to which a political advertisement may be linked." }, { "key": "definition-en", "value": "Something that happens at a particular place and time, organised by one or more agents for a particular purpose, and is of interest to a general audience. This definition excludes natural events such as earthquakes and volcanic eruptions.", "note": "Something that happens at a particular place and time, organised by one or more agents for a particular purpose, and is of interest to a general audience. This definition excludes natural events such as earthquakes and volcanic eruptions." }, { "key": "uri", "value": "http:\/\/data.europa.eu\/m8g\/PublicEvent", "note": "null" }, { "key": "label-en", "value": "Public Event", "note": "null" }, { "key": "REF", "value": "Reg. (EU) 2024\/900, Art. 12(1)(g)(h)", "note": "null" }], "Scope" : "TRANSLATIONS_ONLY", "ap-definition-en" : {"en": "Something that happens at a particular place and time, organised by one or more agents for a particular purpose, and is of interest to a general audience. This definition excludes natural events such as earthquakes and volcanic eruptions."}, "usage" : {"en": "Use this class as the common superclass for ElectionEvent. It represents an event that happens at a particular place and time and is of interest to a general audience. In the political advertising context, use it to describe elections or referendums to which a political advertisement may be linked."}, "ap-label-en" : {"en": "Public Event"}, "definition" : {"en": "Something that happens at a particular place and time, organised by one or more agents for a particular purpose, and is of interest to a general audience. This definition excludes natural events such as earthquakes and volcanic eruptions."}, "label" : {"en": "Public Event"}},
"name": "PublicEvent"
}
, {
"@id": "http://example.org/ElectionEvent",
"@type": "http://www.w3.org/2002/07/owl#Class",
"inpackage": "OTHER_PACKAGE",
"ap-definition-en" : {"en": "An event in which eligible participants formally express a choice or decision to elect representatives or decide on public matters, typically through voting."}, "usage" : {"en": "Use this class to describe an election or referendum to which a political advertisement has a clear and substantial link. The title, level, and date of the event must be disclosed in the transparency notice. The level must be indicated as EU, national, regional, or local."}, "ap-label-en" : {"en": "Election Event"}, "definition" : {"en": "An event in which eligible participants formally express a choice or decision to elect representatives or decide on public matters, typically through voting."}, "label" : {"en": "Election Event"},
"extra": {"EA-Name" : "ElectionEvent", "EA-Guid" : "{C46BB0BD-CC80-4d2f-9B04-AB1DA4E68720}", "EA-Package" : "TTPAV", "EA-Type" : "CLASS", "EA-Parents" : "PublicEvent", "EA-Parents2" : [{ "name": "PublicEvent", "label" : "Public Event", "package" : "TTPAV", "uri" : "http://data.europa.eu/m8g/PublicEvent" }], "parentclasses" : "http://data.europa.eu/m8g/PublicEvent", "label" : "Election Event", "definition" : "An event in which eligible participants formally express a choice or decision to elect representatives or decide on public matters, typically through voting.", "usage" : "Use this class to describe an election or referendum to which a political advertisement has a clear and substantial link. The title, level, and date of the event must be disclosed in the transparency notice. The level must be indicated as EU, national, regional, or local.", "ap-label-en" : "Election Event", "ap-definition-en" : "An event in which eligible participants formally express a choice or decision to elect representatives or decide on public matters, typically through voting.", "ap-usageNote-en" : "", "ap-codelist" : "", "RawTags" : [{ "key": "Superclass", "value": "PublicEvent http:\/\/data.europa.eu\/m8g\/PublicEvent", "note": "null" }, { "key": "label-en", "value": "Election Event", "note": "null" }, { "key": "definition-en", "value": "An event in which eligible participants formally express a choice or decision to elect representatives or decide on public matters, typically through voting.", "note": "null" }, { "key": "uri", "value": "http:\/\/example.org\/ElectionEvent", "note": "null" }, { "key": "usageNote-en", "value": "NOTE", "note": "Use this class to describe an election or referendum to which a political advertisement has a clear and substantial link. The title, level, and date of the event must be disclosed in the transparency notice. The level must be indicated as EU, national, regional, or local." }, { "key": "REF", "value": "Reg. (EU) 2024\/900, Art. 12(1)(g); Impl. Reg. (EU) 2025\/1410, Annex II, \u00A73.9", "note": "null" }], "Scope" : "TRANSLATIONS_ONLY", "ap-definition-en" : {"en": "An event in which eligible participants formally express a choice or decision to elect representatives or decide on public matters, typically through voting."}, "usage" : {"en": "Use this class to describe an election or referendum to which a political advertisement has a clear and substantial link. The title, level, and date of the event must be disclosed in the transparency notice. The level must be indicated as EU, national, regional, or local."}, "ap-label-en" : {"en": "Election Event"}, "definition" : {"en": "An event in which eligible participants formally express a choice or decision to elect representatives or decide on public matters, typically through voting."}, "label" : {"en": "Election Event"}},
"name": "ElectionEvent"
}
, {
"@id": "http://example.org/Funding",
"@type": "http://www.w3.org/2002/07/owl#Class",
"inpackage": "OTHER_PACKAGE",
"ap-definition-en" : {"en": "Financial support provided for a project, activity, or entity, typically by an organisation, government, or individual."}, "usage" : {"en": "Use this class to represent the financial structure supporting a political advertisement or campaign, including direct and indirect funding sources."}, "ap-label-en" : {"en": "Funding"}, "definition" : {"en": "Financial support provided for a project, activity, or entity, typically by an organisation, government, or individual."}, "label" : {"en": "Funding"},
"extra": {"EA-Name" : "Funding ", "EA-Guid" : "{2BA925B9-DE4D-4e55-898D-A44127DD0971}", "EA-Package" : "TTPAV", "EA-Type" : "CLASS", "EA-Parents" : "", "EA-Parents2" : [], "parentclasses" : "", "label" : "Funding", "definition" : "Financial support provided for a project, activity, or entity, typically by an organisation, government, or individual.", "usage" : "Use this class to represent the financial structure supporting a political advertisement or campaign, including direct and indirect funding sources.", "ap-label-en" : "Funding", "ap-definition-en" : "Financial support provided for a project, activity, or entity, typically by an organisation, government, or individual.", "ap-usageNote-en" : "", "ap-codelist" : "", "RawTags" : [{ "key": "definition-en", "value": "Financial support provided for a project, activity, or entity, typically by an organisation, government, or individual.", "note": "null" }, { "key": "label-en", "value": "Funding", "note": "null" }, { "key": "uri", "value": "http:\/\/example.org\/Funding", "note": "null" }, { "key": "usageNote-en", "value": "Use this class to represent the financial structure supporting a political advertisement or campaign, including direct and indirect funding sources.", "note": "Use this class to represent the overall financial structure supporting a political advertisement or campaign, including both direct and indirect funding sources, as required for transparency under EU Regulation 2024\/900." }, { "key": "class-usage-scope", "value": "main", "note": "null" }, { "key": "REF", "value": "Reg. (EU) 2024\/900, Art. 12(1)(d)(e)(f); Impl. Reg. (EU) 2025\/1410, Annex II, \u00A73.5-8.", "note": "null" }], "Scope" : "TRANSLATIONS_ONLY", "ap-definition-en" : {"en": "Financial support provided for a project, activity, or entity, typically by an organisation, government, or individual."}, "usage" : {"en": "Use this class to represent the financial structure supporting a political advertisement or campaign, including direct and indirect funding sources."}, "ap-label-en" : {"en": "Funding"}, "definition" : {"en": "Financial support provided for a project, activity, or entity, typically by an organisation, government, or individual."}, "label" : {"en": "Funding"}},
"name": "Funding"
}
, {
"@id": "http://example.org/Initiative",
"@type": "http://www.w3.org/2002/07/owl#Class",
"inpackage": "OTHER_PACKAGE",
"ap-definition-en" : {"en": "A project,program,or organised effort undertaken to achieve specific objectives, often in a political, legislative, or public context."}, "usage" : {"en": "Use this class to describe a legislative or regulatory initiative to which a political advertisement has a clear and substantial link. The title and level of the initiative must be disclosed in the transparency notice. The title may be shortened."}, "ap-label-en" : {"en": "Initiative"}, "definition" : {"en": "A project,program,or organised effort undertaken to achieve specific objectives, often in a political, legislative, or public context."}, "label" : {"en": "Initiative"},
"extra": {"EA-Name" : "Initiative", "EA-Guid" : "{F5453A31-DC30-4eaf-86A8-A7C87C3786D0}", "EA-Package" : "TTPAV", "EA-Type" : "CLASS", "EA-Parents" : "", "EA-Parents2" : [], "parentclasses" : "", "label" : "Initiative", "definition" : "A project,program,or organised effort undertaken to achieve specific objectives, often in a political, legislative, or public context.", "usage" : "Use this class to describe a legislative or regulatory initiative to which a political advertisement has a clear and substantial link. The title and level of the initiative must be disclosed in the transparency notice. The title may be shortened.", "ap-label-en" : "Initiative", "ap-definition-en" : "A project,program,or organised effort undertaken to achieve specific objectives, often in a political, legislative, or public context.", "ap-usageNote-en" : "", "ap-codelist" : "", "RawTags" : [{ "key": "definition-en", "value": "A project,program,or organised effort undertaken to achieve specific objectives, often in a political, legislative, or public context.", "note": "null" }, { "key": "label-en", "value": "Initiative", "note": "null" }, { "key": "uri", "value": "http:\/\/example.org\/Initiative", "note": "null" }, { "key": "usageNote-en", "value": "Use this class to describe a legislative or regulatory initiative to which a political advertisement has a clear and substantial link. The title and level of the initiative must be disclosed in the transparency notice. The title may be shortened.", "note": "Use this class to describe a legislative or regulatory initiative that is referenced or promoted by a political advertisement. When a political advertisement has a clear and substantial link to a legislative or regulatory initiative, the title and level of the initiative must be disclosed in the transparency notice under Article 12(1)(g) of Regulation (EU) 2024\/900 and Annex II, Template 3, point 9 of Implementing Regulation (EU) 2025\/1410. The title may be shortened." }, { "key": "REF", "value": "Reg. (EU) 2024\/900, Art. 12(1)(g); Impl. Reg. (EU) 2025\/1410, Annex II, \u00A73.9", "note": "null" }], "Scope" : "TRANSLATIONS_ONLY", "ap-definition-en" : {"en": "A project,program,or organised effort undertaken to achieve specific objectives, often in a political, legislative, or public context."}, "usage" : {"en": "Use this class to describe a legislative or regulatory initiative to which a political advertisement has a clear and substantial link. The title and level of the initiative must be disclosed in the transparency notice. The title may be shortened."}, "ap-label-en" : {"en": "Initiative"}, "definition" : {"en": "A project,program,or organised effort undertaken to achieve specific objectives, often in a political, legislative, or public context."}, "label" : {"en": "Initiative"}},
"name": "Initiative"
}
, {
"@id": "http://example.org/PoliticalAdvertisement",
"@type": "http://www.w3.org/2002/07/owl#Class",
"inpackage": "OTHER_PACKAGE",
"ap-definition-en" : {"en": "An advertisement with a political subject matter, including information about its content, format, language, publication dates,and links to legislative processes or votes."}, "usage" : {"en": "Use this class to represent a political advertisement, including its content, format, language, publication period, and any links to related elections or legislative processes."}, "ap-label-en" : {"en": "Political Advertisement"}, "definition" : {"en": "An advertisement with a political subject matter, including information about its content, format, language, publication dates,and links to legislative processes or votes."}, "label" : {"en": "Political Advertisement"},
"extra": {"EA-Name" : "PoliticalAdvertisement", "EA-Guid" : "{6B6FB3CC-9DE7-4a66-B5EB-84102F128780}", "EA-Package" : "TTPAV", "EA-Type" : "CLASS", "EA-Parents" : "", "EA-Parents2" : [], "parentclasses" : "", "label" : "Political Advertisement", "definition" : "An advertisement with a political subject matter, including information about its content, format, language, publication dates,and links to legislative processes or votes.", "usage" : "Use this class to represent a political advertisement, including its content, format, language, publication period, and any links to related elections or legislative processes.", "ap-label-en" : "Political Advertisement", "ap-definition-en" : "An advertisement with a political subject matter, including information about its content, format, language, publication dates,and links to legislative processes or votes.", "ap-usageNote-en" : "", "ap-codelist" : "", "RawTags" : [{ "key": "definition-en", "value": "An advertisement with a political subject matter, including information about its content, format, language, publication dates,and links to legislative processes or votes.", "note": "null" }, { "key": "label-en", "value": "Political Advertisement", "note": "null" }, { "key": "uri", "value": "http:\/\/example.org\/PoliticalAdvertisement", "note": "null" }, { "key": "usageNote-en", "value": "Use this class to represent a political advertisement, including its content, format, language, publication period, and any links to related elections or legislative processes.", "note": "null" }, { "key": "class-usage-scope", "value": "main", "note": "null" }, { "key": "REF", "value": "Reg. (EU) 2024\/900, Art. 11(1); Impl. Reg. (EU) 2025\/1410, Annex I", "note": "null" }], "Scope" : "TRANSLATIONS_ONLY", "ap-definition-en" : {"en": "An advertisement with a political subject matter, including information about its content, format, language, publication dates,and links to legislative processes or votes."}, "usage" : {"en": "Use this class to represent a political advertisement, including its content, format, language, publication period, and any links to related elections or legislative processes."}, "ap-label-en" : {"en": "Political Advertisement"}, "definition" : {"en": "An advertisement with a political subject matter, including information about its content, format, language, publication dates,and links to legislative processes or votes."}, "label" : {"en": "Political Advertisement"}},
"name": "PoliticalAdvertisement"
}
, {
"@id": "http://example.org/Targeting",
"@type": "http://www.w3.org/2002/07/owl#Class",
"inpackage": "OTHER_PACKAGE",
"ap-definition-en" : {"en": "The set of criteria, characteristics, or parameters used to define the intended audience or recipients of a political advertisement."}, "usage" : {"en": "Use this class to document all targeting and ad-delivery techniques based on personal data used for the political advertisement. Populate this class when the online political advertisement uses such techniques. The label of the political advertisement must also include a statement about the use of targeting or ad-delivery techniques."}, "ap-label-en" : {"en": "Targeting"}, "definition" : {"en": "The set of criteria, characteristics, or parameters used to define the intended audience or recipients of a political advertisement."}, "label" : {"en": "Targeting"},
"extra": {"EA-Name" : "Targeting", "EA-Guid" : "{8161C202-FCF7-4553-9B5D-6C18BA75F5A9}", "EA-Package" : "TTPAV", "EA-Type" : "CLASS", "EA-Parents" : "", "EA-Parents2" : [], "parentclasses" : "", "label" : "Targeting", "definition" : "The set of criteria, characteristics, or parameters used to define the intended audience or recipients of a political advertisement.", "usage" : "Use this class to document all targeting and ad-delivery techniques based on personal data used for the political advertisement. Populate this class when the online political advertisement uses such techniques. The label of the political advertisement must also include a statement about the use of targeting or ad-delivery techniques.", "ap-label-en" : "Targeting", "ap-definition-en" : "The set of criteria, characteristics, or parameters used to define the intended audience or recipients of a political advertisement.", "ap-usageNote-en" : "", "ap-codelist" : "", "RawTags" : [{ "key": "definition-en", "value": "The set of criteria, characteristics, or parameters used to define the intended audience or recipients of a political advertisement.", "note": "null" }, { "key": "label-en", "value": "Targeting", "note": "null" }, { "key": "uri", "value": "http:\/\/example.org\/Targeting", "note": "null" }, { "key": "class-usage-scope", "value": "main", "note": "null" }, { "key": "usageNote-en", "value": "NOTE", "note": "Use this class to document all targeting and ad-delivery techniques based on personal data used for the political advertisement. Populate this class when the online political advertisement uses such techniques. The label of the political advertisement must also include a statement about the use of targeting or ad-delivery techniques." }, { "key": "REF", "value": "Reg. (EU) 2024\/900, Art. 11(1)(d), Art. 12(1)(l), Art. 18, Art. 19; Impl. Reg. (EU) 2025\/1410, Annex II, \u00A73.14-16", "note": "null" }], "Scope" : "TRANSLATIONS_ONLY", "ap-definition-en" : {"en": "The set of criteria, characteristics, or parameters used to define the intended audience or recipients of a political advertisement."}, "usage" : {"en": "Use this class to document all targeting and ad-delivery techniques based on personal data used for the political advertisement. Populate this class when the online political advertisement uses such techniques. The label of the political advertisement must also include a statement about the use of targeting or ad-delivery techniques."}, "ap-label-en" : {"en": "Targeting"}, "definition" : {"en": "The set of criteria, characteristics, or parameters used to define the intended audience or recipients of a political advertisement."}, "label" : {"en": "Targeting"}},
"name": "Targeting"
}
, {
"@id": "http://example.org/TransparencyNotice",
"@type": "http://www.w3.org/2002/07/owl#Class",
"inpackage": "OTHER_PACKAGE",
"ap-definition-en" : {"en": "A record providing information about a political advertisement, its funding, sponsors, targeting, and related entities, to ensure transparency and compliance with legal requirements."}, "usage" : {"en": "Use this class as the root element for transparency disclosures related to a political advertisement."}, "ap-label-en" : {"en": "Transparency Notice"}, "definition" : {"en": "A record providing information about a political advertisement, its funding, sponsors, targeting, and related entities, to ensure transparency and compliance with legal requirements."}, "label" : {"en": "Transparency Notice"},
"extra": {"EA-Name" : "TransparencyNotice", "EA-Guid" : "{BA51F248-523B-418c-9F76-1672AF9FE56C}", "EA-Package" : "TTPAV", "EA-Type" : "CLASS", "EA-Parents" : "", "EA-Parents2" : [], "parentclasses" : "", "label" : "Transparency Notice", "definition" : "A record providing information about a political advertisement, its funding, sponsors, targeting, and related entities, to ensure transparency and compliance with legal requirements.", "usage" : "Use this class as the root element for transparency disclosures related to a political advertisement.", "ap-label-en" : "Transparency Notice", "ap-definition-en" : "A record providing information about a political advertisement, its funding, sponsors, targeting, and related entities, to ensure transparency and compliance with legal requirements.", "ap-usageNote-en" : "", "ap-codelist" : "", "RawTags" : [{ "key": "definition-en", "value": "A record providing information about a political advertisement, its funding, sponsors, targeting, and related entities, to ensure transparency and compliance with legal requirements.", "note": "null" }, { "key": "label-en", "value": "Transparency Notice", "note": "null" }, { "key": "uri", "value": "http:\/\/example.org\/TransparencyNotice", "note": "null" }, { "key": "usageNote-en", "value": "Use this class as the root element for transparency disclosures related to a political advertisement.", "note": "Use this class as the root element for all transparency disclosures related to political advertising. Every political advertisement must be accompanied by a transparency notice containing the information listed in Article 12(1) of Regulation (EU) 2024\/900. The notice must be easily retrievable at all times during the period of publication, kept up-to-date, available in machine-readable format for online advertisements, written in the language of the advertisement, and compliant with accessibility requirements under Article 12(3) and Annex III of Implementing Regulation (EU) 2025\/1410. It must be retained for seven years after the last publication." }, { "key": "class-usage-scope", "value": "main", "note": "null" }, { "key": "REF", "value": "Reg. (EU) 2024\/900, Art. 11(1)(e), Art. 12; Impl. Reg. (EU) 2025\/1410, Annex II, \u00A73; Annex III", "note": "null" }], "Scope" : "TRANSLATIONS_ONLY", "ap-definition-en" : {"en": "A record providing information about a political advertisement, its funding, sponsors, targeting, and related entities, to ensure transparency and compliance with legal requirements."}, "usage" : {"en": "Use this class as the root element for transparency disclosures related to a political advertisement."}, "ap-label-en" : {"en": "Transparency Notice"}, "definition" : {"en": "A record providing information about a political advertisement, its funding, sponsors, targeting, and related entities, to ensure transparency and compliance with legal requirements."}, "label" : {"en": "Transparency Notice"}},
"name": "TransparencyNotice"
}
, {
"@id": "http://www.w3.org/1999/02/22-rdf-syntax-ns#langString",
"@type": "http://www.w3.org/2002/07/owl#Class",
"inpackage": "OTHER_PACKAGE",
"ap-definition-en" : {"en": "The text data type is a combination of a string and a language identifier."}, "usage" : {"en": "It is useful for names and descriptions that are available in multiple languages. Where this is so, each version of the data should be included and each one associated with the relevant language identifier. RFC 3066 provides a commonly used set of identifiers for natural languages. This is the set recognised by UN\/CEFACT and XML Schema.\r\nLanguages are represented by two character codes, optionally followed by a locale definition such as \"de\" meaning German and \"de-at\" meaning \"German as spoken in Austria.\""}, "ap-label-en" : {"en": "Text"}, "definition" : {"en": "The text data type is a combination of a string and a language identifier."}, "label" : {"en": "Text"},
"extra": {"EA-Name" : "Text", "EA-Guid" : "{31427F3B-588A-40dd-968A-ED4472D160DC}", "EA-Package" : "datatypes", "EA-Type" : "DATATYPE", "EA-Parents" : "", "EA-Parents2" : [], "parentclasses" : "", "label" : "Text", "definition" : "The text data type is a combination of a string and a language identifier.", "usage" : "It is useful for names and descriptions that are available in multiple languages. Where this is so, each version of the data should be included and each one associated with the relevant language identifier. RFC 3066 provides a commonly used set of identifiers for natural languages. This is the set recognised by UN\/CEFACT and XML Schema.\r\nLanguages are represented by two character codes, optionally followed by a locale definition such as \"de\" meaning German and \"de-at\" meaning \"German as spoken in Austria.\"", "ap-label-en" : "Text", "ap-definition-en" : "The text data type is a combination of a string and a language identifier.", "ap-usageNote-en" : "", "ap-codelist" : "", "RawTags" : [{ "key": "class-usage-scope", "value": "datatype", "note": "null" }, { "key": "definition-en", "value": "The text data type is a combination of a string and a language identifier.", "note": "null" }, { "key": "label-en", "value": "Text", "note": "null" }, { "key": "literal", "value": "True", "note": "null" }, { "key": "uri", "value": "http:\/\/www.w3.org\/1999\/02\/22-rdf-syntax-ns#langString", "note": "null" }, { "key": "usageNote-en", "value": "NOTE", "note": "It is useful for names and descriptions that are available in multiple languages. Where this is so, each version of the data should be included and each one associated with the relevant language identifier. RFC 3066 provides a commonly used set of identifiers for natural languages. This is the set recognised by UN\/CEFACT and XML Schema.\r\nLanguages are represented by two character codes, optionally followed by a locale definition such as \"de\" meaning German and \"de-at\" meaning \"German as spoken in Austria.\"" }], "Scope" : "NOTHING", "ap-definition-en" : {"en": "The text data type is a combination of a string and a language identifier."}, "usage" : {"en": "It is useful for names and descriptions that are available in multiple languages. Where this is so, each version of the data should be included and each one associated with the relevant language identifier. RFC 3066 provides a commonly used set of identifiers for natural languages. This is the set recognised by UN\/CEFACT and XML Schema.\r\nLanguages are represented by two character codes, optionally followed by a locale definition such as \"de\" meaning German and \"de-at\" meaning \"German as spoken in Austria.\""}, "ap-label-en" : {"en": "Text"}, "definition" : {"en": "The text data type is a combination of a string and a language identifier."}, "label" : {"en": "Text"}},
"name": "Text"
}
