          },
          {
            "key": "uri",
            "note": "null",
            "value": "http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"
          },
          {
            "key": "usageNote-en",
            "note": "It is useful for names and descriptions that are available in multiple languages. Where this is so, each version of the data should be included and each one associated with the relevant language identifier. RFC 3066 provides a commonly used set of identifiers for natural languages. This is the set recognised by UN/CEFACT and XML Schema.\r\nLanguages are represented by two character codes, optionally followed by a locale definition such as \"de\" meaning German and \"de-at\" meaning \"German as spoken in Austria.\"",
            "value": "NOTE"
          }
        ],
