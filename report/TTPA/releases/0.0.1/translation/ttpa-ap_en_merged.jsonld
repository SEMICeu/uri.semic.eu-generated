          "EA-Package": "",
          "uri": "http://www.w3.org/2000/01/rdf-schema#Literal"
        }
      ],
      "usage": {
        "en": "A globally unique identifier for each instance of an address. Use this property where a persistent, machine-readable identifier for the address is available."
      }
