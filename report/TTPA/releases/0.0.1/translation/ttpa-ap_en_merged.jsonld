    {
      "@id": "http://example.org/TransparencyNotice",
      "@type": "http://www.w3.org/2002/07/owl#Class",
      "EA-Guid": "{BA51F248-523B-418c-9F76-1672AF9FE56C}",
      "ap-definition-en": {
        "en": "A record providing information about a political advertisement, its funding, sponsors, targeting, and related entities, to ensure transparency and compliance with legal requirements."
      },
      "ap-label-en": {
        "en": "Transparency Notice"
      },
      "definition": {
        "en": "A record providing information about a political advertisement, its funding, sponsors, targeting, and related entities, to ensure transparency and compliance with legal requirements."
      },
      "extra": {
        "EA-Guid": "{BA51F248-523B-418c-9F76-1672AF9FE56C}",
        "EA-Name": "TransparencyNotice",
        "EA-Package": "TTPAV",
        "EA-Parents": "",
        "EA-Parents2": [],
        "EA-Type": "CLASS",
        "RawTags": [
          {
            "key": "definition-en",
            "note": "null",
            "value": "A record providing information about a political advertisement, its funding, sponsors, targeting, and related entities, to ensure transparency and compliance with legal requirements."
          },
          {
            "key": "label-en",
            "note": "null",
            "value": "Transparency Notice"
          },
          {
            "key": "uri",
            "note": "null",
            "value": "http://example.org/TransparencyNotice"
          },
          {
            "key": "usageNote-en",
            "note": "Use this class as the root element for all transparency disclosures related to political advertising. Every political advertisement must be accompanied by a transparency notice containing the information listed in Article 12(1) of Regulation (EU) 2024/900. The notice must be easily retrievable at all times during the period of publication, kept up-to-date, available in machine-readable format for online advertisements, written in the language of the advertisement, and compliant with accessibility requirements under Article 12(3) and Annex III of Implementing Regulation (EU) 2025/1410. It must be retained for seven years after the last publication.",
            "value": "Use this class as the root element for transparency disclosures related to a political advertisement."
          },
          {
            "key": "class-usage-scope",
            "note": "null",
            "value": "main"
          },
          {
            "key": "REF",
            "note": "null",
            "value": "Reg. (EU) 2024/900, Art. 11(1)(e), Art. 12; Impl. Reg. (EU) 2025/1410, Annex II, §3; Annex III"
          }
        ],
        "Scope": "TRANSLATIONS_ONLY",
        "ap-codelist": "",
        "ap-definition-en": {
          "en": "A record providing information about a political advertisement, its funding, sponsors, targeting, and related entities, to ensure transparency and compliance with legal requirements."
        },
