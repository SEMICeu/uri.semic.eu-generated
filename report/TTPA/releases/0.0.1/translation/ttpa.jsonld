    {
      "@id": "http://www.w3.org/ns/legal#legalName",
      "@type": "http://www.w3.org/2002/07/owl#DatatypeProperty",
      "name": "legalName",
      "inpackage": "OTHER_PACKAGE",
      "ap-definition-en": {
        "en": "The name under which the Legal Entity is legally registered."
      },
      "usage": {
        "en": "Provide the name under which the legal entity, sponsor, or paying entity is legally registered.\r\nThe legal name is different from the alternative (trade) name which is a pseudonym used by companies that do not operate under their registered company name.\r\nA business might have more than one legal name, particularly in countries with more than one official language. In such cases, and where the encoding technology allows, the language of the string should be identified."
      },
      "ap-label-en": {
        "en": "legal name"
      },
      "definition": {
        "en": "The name under which the Legal Entity is legally registered."
      },
      "label": {
