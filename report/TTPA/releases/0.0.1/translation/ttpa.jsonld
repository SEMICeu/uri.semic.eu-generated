    {
      "@id": "http://www.w3.org/ns/locn#adminUnitL1",
      "@type": "http://www.w3.org/2002/07/owl#DatatypeProperty",
      "name": "administrativeUnitLevel1",
      "inpackage": "OTHER_PACKAGE",
      "ap-definition-en": {
        "en": "The name of the uppermost level of the address, almost always a country."
      },
      "usage": {
        "en": "Provide the country of the address using a controlled vocabulary. Mandatory component of any postal or establishment address associated with a sponsor, paying entity, or controlling entity, as required by Annex II, Template 3, note 1 of Implementing Regulation (EU) 2025/1410."
      },
      "ap-label-en": {
        "en": "administrative unit level 1"
      },
      "definition": {
        "en": "The name of the uppermost level of the address, almost always a country."
      },
      "label": {
        "en": "administrative unit level 1"
      },
      "extra": {
        "EA-Name": "adminUnitL1",
        "EA-Guid": "{4F623F23-BF33-4cf0-B750-EB6AD826B108}",
        "EA-Package": "Core Location",
