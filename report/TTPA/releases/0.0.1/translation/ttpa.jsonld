          }
        ],
        "parentclasses": "http://xmlns.com/foaf/0.1/Agent",
        "label": {
          "en": "Legal Entity"
        },
        "definition": {
          "en": "A self-employed person,company,or organization that has legal rights and obligations."
        },
        "usage": {
          "en": "Use this class to represent any legal entity involved in the context of a political advertisement, including the sponsor, the paying entity, or the legal entity ultimately controlling the sponsor. This class supports the requirements for transparency notices under EU Regulation 2024/900, which mandate disclosure of the identity, contact details, and registration information for all such entities."
        },
        "ap-label-en": {
          "en": "Legal Entity"
        },
        "ap-definition-en": {
          "en": "A self-employed person,company,or organization that has legal rights and obligations."
        },
        "ap-usageNote-en": "",
        "ap-codelist": "",
        "RawTags": [
          {
            "key": "definition-en",
            "value": "A self-employed person,company,or organization that has legal rights and obligations.",
            "note": "A legal entity able to transact business, typically registered with a body able to confer legal status such as a national business register.\r\nIn RDF terms, a legal entity is a sub class of dcterms:Agent and foaf:Agent.\r\nIn XML terms, this is equivalent to the UN/CEFACT term 'Business profile"
          },
          {
            "key": "label-en",
            "value": "Legal Entity",
            "note": "null"
          },
          {
            "key": "parentURI",
            "value": "http://www.w3.org/ns/org#FormalOrganization",
            "note": "null"
          },
          {
