        "EA-Type": "CLASS",
        "EA-Parents": "",
        "EA-Parents2": [],
        "parentclasses": "",
        "label": {
          "en": "Transparency Notice"
        },
        "definition": {
          "en": "A record providing information about a political advertisement, its funding, sponsors, targeting, and related entities, to ensure transparency and compliance with legal requirements."
        },
        "usage": {
          "en": "Use this class as the root element for transparency disclosures related to political advertising."
        },
        "ap-label-en": {
          "en": "Transparency Notice"
        },
        "ap-definition-en": {
          "en": "A record providing information about a political advertisement, its funding, sponsors, targeting, and related entities, to ensure transparency and compliance with legal requirements."
        },
        "ap-usageNote-en": "",
        "ap-codelist": "",
        "RawTags": [
          {
            "key": "definition-en",
            "value": "A record providing information about a political advertisement, its funding, sponsors, targeting, and related entities, to ensure transparency and compliance with legal requirements.",
            "note": "null"
          },
          {
            "key": "label-en",
            "value": "Transparency Notice",
            "note": "null"
          },
          {
            "key": "uri",
            "value": "http://example.org/TransparencyNotice",
            "note": "null"
          },
          {
            "key": "usageNote-en",
            "value": "Use this class as the root element for transparency disclosures related to political advertising.",
            "note": "Use this class as the root element for all transparency disclosures related to political advertising. Every political advertisement must be accompanied by a transparency notice containing the information listed in Article 12(1) of Regulation (EU) 2024/900. The notice must be easily retrievable at all times during the period of publication, kept up-to-date, available in machine-readable format for online advertisements, written in the language of the advertisement, and compliant with accessibility requirements under Article 12(3) and Annex III of Implementing Regulation (EU) 2025/1410. It must be retained for seven years after the last publication."
          },
          {
            "key": "class-usage-scope",
            "value": "main",
            "note": "null"
          }
        ],
        "Scope": "TRANSLATIONS_ONLY"
      },
      "name": "TransparencyNotice"
    },
    {
      "@id": "http://www.w3.org/1999/02/22-rdf-syntax-ns#langString",
      "@type": "http://www.w3.org/2002/07/owl#Class",
      "inpackage": "OTHER_PACKAGE",
      "ap-definition-en": {
        "en": "The text data type is a combination of a string and a language identifier."
      },
      "usage": {
        "en": "It is useful for names and descriptions that are available in multiple languages. Where this is so, each version of the data should be included and each one associated with the relevant language identifier. RFC 3066 provides a commonly used set of identifiers for natural languages. This is the set recognised by UN/CEFACT and XML Schema.\r\nLanguages are represented by two character codes, optionally followed by a locale definition such as \"de\" meaning German and \"de-at\" meaning \"German as spoken in Austria.\""
      },
      "ap-label-en": {
        "en": "Text"
      },
      "definition": {
        "en": "The text data type is a combination of a string and a language identifier."
      },
      "label": {
