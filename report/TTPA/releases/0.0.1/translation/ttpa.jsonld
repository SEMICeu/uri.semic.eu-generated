        },
        "label": {
          "en": "has time"
        },
        "definition": {
          "en": "\tThe association of a temporal entity (instant or interval) to any thing."
        },
        "usage": {
          "en": "Provide the temporal instant or interval associated with the public event. For elections and referendums, this should correspond to the date(s) of the event as required by Article 12(1)(g) of Regulation (EU) 2024/900 and Annex II, Template 3, point 9 of Implementing Regulation (EU) 2025/1410."
        },
        "ap-label-en": {
