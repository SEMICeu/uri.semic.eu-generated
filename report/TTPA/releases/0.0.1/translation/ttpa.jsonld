    {
      "@id": "http://www.w3.org/ns/legal#LegalEntity",
      "@type": "http://www.w3.org/2002/07/owl#Class",
      "inpackage": "OTHER_PACKAGE",
      "ap-definition-en": {
        "en": "A self-employed person,company,or organization that has legal rights and obligations."
      },
      "usage": {
        "en": "Use this class to represent any legal entity involved in the context of a political advertisement, including the sponsor, the paying entity, or the legal entity ultimately controlling the sponsor. This class supports the requirements for transparency notices under EU Regulation 2024/900, which mandate disclosure of the identity, contact details, and registration information for all such entities."
      },
      "ap-label-en": {
        "en": "Legal Entity"
      },
      "definition": {
        "en": "A self-employed person,company,or organization that has legal rights and obligations."
      },
      "label": {
        "en": "Legal Entity"
      },
      "extra": {
        "EA-Name": "LegalEntity",
        "EA-Guid": "{D7465C4B-0B62-41dc-808A-8F0E04B79276}",
        "EA-Package": "Core Business",
        "EA-Type": "CLASS",
        "EA-Parents": "Agent",
        "EA-Parents2": [
          {
            "name": "Agent",
