    {
      "@id": "http://example.org/ElectionEvent",
      "@type": "http://www.w3.org/2002/07/owl#Class",
      "inpackage": "OTHER_PACKAGE",
      "ap-definition-en": {
        "en": "An event in which eligible participants formally express a choice or decision to elect representatives or decide on public matters, typically through voting."
      },
      "usage": {
        "en": "Use this class to describe an election event that is referenced or linked to a political advertisement. When a political advertisement has a clear and substantial link to an election, the title, level, and date of the election must be disclosed in the transparency notice as required by Article 12(1)(g) of Regulation (EU) 2024/900 and Annex II, Template 3, point 9 of Implementing Regulation (EU) 2025/1410. The level must be indicated as EU, national, regional, or local."
      },
      "ap-label-en": {
        "en": "Election Event"
      },
      "definition": {
        "en": "An event in which eligible participants formally express a choice or decision to elect representatives or decide on public matters, typically through voting."
      },
      "label": {
        "en": "Election Event"
      },
      "extra": {
        "EA-Name": "ElectionEvent",
        "EA-Guid": "{C46BB0BD-CC80-4d2f-9B04-AB1DA4E68720}",
        "EA-Package": "TTPAV",
        "EA-Type": "CLASS",
        "EA-Parents": "PublicEvent",
        "EA-Parents2": [
          {
            "name": "PublicEvent",
            "label": "Public Event",
            "package": "TTPAV",
            "uri": "http://data.europa.eu/m8g/PublicEvent"
          }
        ],
        "parentclasses": "http://data.europa.eu/m8g/PublicEvent",
        "label": {
          "en": "Election Event"
        },
        "definition": {
          "en": "An event in which eligible participants formally express a choice or decision to elect representatives or decide on public matters, typically through voting."
        },
        "usage": {
          "en": "Use this class to describe an election event that is referenced or linked to a political advertisement. When a political advertisement has a clear and substantial link to an election, the title, level, and date of the election must be disclosed in the transparency notice as required by Article 12(1)(g) of Regulation (EU) 2024/900 and Annex II, Template 3, point 9 of Implementing Regulation (EU) 2025/1410. The level must be indicated as EU, national, regional, or local."
        },
        "ap-label-en": {
          "en": "Election Event"
        },
        "ap-definition-en": {
          "en": "An event in which eligible participants formally express a choice or decision to elect representatives or decide on public matters, typically through voting."
        },
        "ap-usageNote-en": "",
