    {
      "@id": "http://www.w3.org/ns/locn#address",
      "@type": "http://www.w3.org/2002/07/owl#ObjectProperty",
      "name": "address",
      "inpackage": "OTHER_PACKAGE",
      "ap-definition-en": {
        "en": "An \"address representation\" as conceptually defined by the INSPIRE Address Representation data type. The locn:addressId property may be used to link this locn:Address to other representations."
      },
      "usage": {
        "en": "For individuals, only if isAddressPublic=true; for organisations, use as the main correspondence address.\r\n\r\nProvide the address as required for sponsors or paying entities (Article 12(1)(a)-(b))."
      },
      "ap-label-en": {
        "en": "address"
      },
      "definition": {
