    {
      "@id": "http://example.org/CampaignFinancialInfo",
      "@type": "http://www.w3.org/2002/07/owl#Class",
      "inpackage": "OTHER_PACKAGE",
      "ap-definition-en": {
        "en": "Information describing the financial aspects of a political campaign,including sources of funding,expenditures,and financial disclosures."
      },
      "usage": {
        "en": "Use this class to provide aggregated financial information for a political advertising campaign, including total amount and currency, as required for transparency and reporting under EU Regulation 2024/900."
      },
      "ap-label-en": {
        "en": "Campaign Financial Information"
      },
      "definition": {
