    {
      "@id": "http://example.org/Targeting",
      "@type": "http://www.w3.org/2002/07/owl#Class",
      "inpackage": "OTHER_PACKAGE",
      "ap-definition-en": {
        "en": "The set of criteria, characteristics, or parameters used to define the intended audience or recipients of a political advertisement."
      },
      "usage": {
        "en": "Use this class to document all targeting and ad-delivery techniques based on personal data used for the political advertisement. Population of this class is mandatory when online political advertisements use such techniques, under Article 12(1)(l) of Regulation (EU) 2024/900 and Annex II, Template 3, points 1416 of Implementing Regulation (EU) 2025/1410. The label of the political advertisement must also include a statement about the use of targeting or ad-delivery techniques under Article 11(1)(d) of Regulation (EU) 2024/900."
      },
      "ap-label-en": {
        "en": "Targeting"
      },
      "definition": {
        "en": "The set of criteria, characteristics, or parameters used to define the intended audience or recipients of a political advertisement."
      },
      "label": {
        "en": "Targeting"
      },
      "extra": {
        "EA-Name": "Targeting",
        "EA-Guid": "{8161C202-FCF7-4553-9B5D-6C18BA75F5A9}",
        "EA-Package": "TTPAV",
        "EA-Type": "CLASS",
        "EA-Parents": "",
        "EA-Parents2": [],
        "parentclasses": "",
        "label": {
          "en": "Targeting"
        },
        "definition": {
          "en": "The set of criteria, characteristics, or parameters used to define the intended audience or recipients of a political advertisement."
        },
        "usage": {
          "en": "Use this class to document all targeting and ad-delivery techniques based on personal data used for the political advertisement. Population of this class is mandatory when online political advertisements use such techniques, under Article 12(1)(l) of Regulation (EU) 2024/900 and Annex II, Template 3, points 1416 of Implementing Regulation (EU) 2025/1410. The label of the political advertisement must also include a statement about the use of targeting or ad-delivery techniques under Article 11(1)(d) of Regulation (EU) 2024/900."
        },
        "ap-label-en": {
          "en": "Targeting"
        },
        "ap-definition-en": {
          "en": "The set of criteria, characteristics, or parameters used to define the intended audience or recipients of a political advertisement."
        },
        "ap-usageNote-en": "",
        "ap-codelist": "",
        "RawTags": [
          {
            "key": "definition-en",
            "value": "The set of criteria, characteristics, or parameters used to define the intended audience or recipients of a political advertisement.",
            "note": "null"
          },
          {
            "key": "label-en",
            "value": "Targeting",
            "note": "null"
          },
          {
            "key": "uri",
            "value": "http://example.org/Targeting",
            "note": "null"
          },
          {
            "key": "class-usage-scope",
            "value": "main",
            "note": "null"
          },
          {
            "key": "usageNote-en",
            "value": "NOTE",
            "note": "Use this class to document all targeting and ad-delivery techniques based on personal data used for the political advertisement. Population of this class is mandatory when online political advertisements use such techniques, under Article 12(1)(l) of Regulation (EU) 2024/900 and Annex II, Template 3, points 1416 of Implementing Regulation (EU) 2025/1410. The label of the political advertisement must also include a statement about the use of targeting or ad-delivery techniques under Article 11(1)(d) of Regulation (EU) 2024/900."
          }
        ],
        "Scope": "TRANSLATIONS_ONLY"
      },
      "name": "Targeting"
    },
    {
      "@id": "http://example.org/TransparencyNotice",
      "@type": "http://www.w3.org/2002/07/owl#Class",
      "inpackage": "OTHER_PACKAGE",
      "ap-definition-en": {
        "en": "A record providing information about a political advertisement, its funding, sponsors, targeting, and related entities, to ensure transparency and compliance with legal requirements."
      },
      "usage": {
        "en": "Use this class as the root element for transparency disclosures related to political advertising."
      },
      "ap-label-en": {
        "en": "Transparency Notice"
      },
      "definition": {
        "en": "A record providing information about a political advertisement, its funding, sponsors, targeting, and related entities, to ensure transparency and compliance with legal requirements."
      },
      "label": {
        "en": "Transparency Notice"
      },
      "extra": {
        "EA-Name": "Transparency Notice",
