      "@id": "http://data.europa.eu/m8g/PublicEvent",
      "@type": "http://www.w3.org/2002/07/owl#Class",
      "inpackage": "OTHER_PACKAGE",
      "ap-definition-en": {
        "en": "Something that happens at a particular place and time, organised by one or more agents for a particular purpose, and is of interest to a general audience. This definition excludes natural events such as earthquakes and volcanic eruptions."
      },
      "ap-label-en": {
        "en": "Public Event"
      },
      "definition": {
        "en": "Something that happens at a particular place and time, organised by one or more agents for a particular purpose, and is of interest to a general audience. This definition excludes natural events such as earthquakes and volcanic eruptions."
