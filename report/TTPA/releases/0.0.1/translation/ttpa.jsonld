        "EA-Domain": "Funding ",
        "EA-Domain-Guid": "{2BA925B9-DE4D-4e55-898D-A44127DD0971}",
        "EA-Range": "Text",
        "RangeData": {
          "EA-Name": "Text",
          "EA-GUID": "{31427F3B-588A-40dd-968A-ED4472D160DC}",
          "EA-Package": "datatypes",
          "uri": "http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"
        },
        "label": {
          "en": "calculation methodology"
        },
        "definition": {
          "en": "The method or approach used to calculate the amount or allocation of funding."
        },
        "usage": {
          "en": "Describe the methodology used to calculate the aggregated amounts and value of other benefits received by the providers of political advertising services, including whether the figures reflect invoiced, budgeted, and/or charged amounts and whether VAT is included. For in-kind benefits, indicate the valuation method used. This information is mandatory in the transparency notice under Article 12(1)(f) of Regulation (EU) 2024/900 and Annex II, Template 3, point 8 of Implementing Regulation (EU) 2025/1410."
        },
        "ap-label-en": {
          "en": "calculation methodology"
        },
        "ap-definition-en": {
          "en": "The method or approach used to calculate the amount or allocation of funding."
        },
        "ap-usageNote-en": "",
        "ap-codelist": "",
        "RawTags": [
          {
            "key": "label-en",
            "value": "calculation methodology",
            "note": "null"
          },
          {
            "key": "definition-en",
            "value": "The method or approach used to calculate the amount or allocation of funding.",
            "note": "null"
          },
          {
            "key": "uri",
            "value": "http://example.org/calculationMethodology",
            "note": "null"
          },
          {
            "key": "usageNote-en",
            "value": "NOTE",
            "note": "Describe the methodology used to calculate the aggregated amounts and value of other benefits received by the providers of political advertising services, including whether the figures reflect invoiced, budgeted, and/or charged amounts and whether VAT is included. For in-kind benefits, indicate the valuation method used. This information is mandatory in the transparency notice under Article 12(1)(f) of Regulation (EU) 2024/900 and Annex II, Template 3, point 8 of Implementing Regulation (EU) 2025/1410."
          }
        ],
        "Scope": "TRANSLATIONS_ONLY"
      },
