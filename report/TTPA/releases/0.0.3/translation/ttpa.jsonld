            "note": "null"
          },
          {
            "key": "uri",
            "value": "http://example.org/Initiative",
            "note": "null"
          },
          {
            "key": "usageNote-en",
            "value": "Use this class to describe a legislative or regulatory initiative to which a political advertisement has a clear and substantial link. The title and level of the initiative must be disclosed in the transparency notice. The title may be shortened.",
            "note": "Use this class to describe a legislative or regulatory initiative that is referenced or promoted by a political advertisement. When a political advertisement has a clear and substantial link to a legislative or regulatory initiative, the title and level of the initiative must be disclosed in the transparency notice under Article 12(1)(g) of Regulation (EU) 2024/900 and Annex II, Template 3, point 9 of Implementing Regulation (EU) 2025/1410. The title may be shortened."
          },
          {
            "key": "REF",
