    {
      "@id": "http://www.w3.org/ns/locn#address",
      "@type": "http://www.w3.org/2002/07/owl#ObjectProperty",
      "name": "address",
      "inpackage": "ACTIVE_PACKAGE",
      "ap-definition-en": {
        "en": "An \"address representation\" as conceptually defined by the INSPIRE Address Representation data type. The locn:addressId property may be used to link this locn:Address to other representations."
      },
      "usage": {
        "en": "Links an Agent to its postal address. For natural persons, only provide if the address has been made public. For organisations, use as the main correspondence address."
      },
      "ap-label-en": {
        "en": "address"
      },
      "definition": {
