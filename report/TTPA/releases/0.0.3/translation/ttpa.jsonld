    {
      "@id": "http://example.org/TargetingTechnique",
      "@type": "http://www.w3.org/2002/07/owl#Class",
      "ap-definition-en": {
        "en": "The set of criteria, characteristics, or parameters used to define the intended audience or recipients of a political advertisement."
      },
      "usage": {
        "en": "Targeting techniques determine who will see a political advertisement, for example, by using demographic, geographic, or behavioural data.\r\n"
