  "classes": [
    {
      "@id": "http://example.org/AdDeliveryTechnique",
      "@type": "http://www.w3.org/2002/07/owl#Class",
      "ap-definition-en": {
        "en": "A method or process used to determine how, when, and in what context a political advertisement is delivered to its intended audience, including the use of algorithms, AI systems, or other automated means. Ad-delivery techniques are optimisation techniques used to increase the circulation, reach or visibility of a political advertisement on the basis of the automated processing of personal data."
      },
      "usage": {
        "en": "Ad delivery techniques influence the placement, timing, and frequency of advertisements, often using optimisation algorithms or AI to maximise engagement or reach."
      },
      "ap-label-en": {
        "en": "Ad Delivery Technique"
      },
      "definition": {
        "en": "A method or process used to determine how, when, and in what context a political advertisement is delivered to its intended audience, including the use of algorithms, AI systems, or other automated means. Ad-delivery techniques are optimisation techniques used to increase the circulation, reach or visibility of a political advertisement on the basis of the automated processing of personal data."
      },
      "label": {
        "en": "Ad Delivery Technique"
      },
      "extra": {
        "EA-Name": "AdDeliveryTechnique",
        "EA-Guid": "{0D9FB465-1AC4-4bca-8DBC-C33B356FDD87}",
