    {
      "@id": "http://example.org/ElectionEvent",
      "@type": "http://www.w3.org/2002/07/owl#Class",
      "ap-definition-en": {
        "en": "An event in which eligible participants formally express a choice or decision to elect representatives or decide on public matters, typically through voting."
      },
      "usage": {
        "en": "Use this class to describe an election or referendum to which a political advertisement has a clear and substantial link. The title, level, and date of the event must be disclosed in the transparency notice. The level must be indicated as EU, national, regional, or local."
      },
      "ap-label-en": {
        "en": "Election Event"
      },
      "definition": {
        "en": "An event in which eligible participants formally express a choice or decision to elect representatives or decide on public matters, typically through voting."
      },
      "label": {
        "en": "Election Event"
      },
