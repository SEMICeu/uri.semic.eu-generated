    {
      "@id": "http://data.europa.eu/p4s/EvidenceOfCertificateAdmissionSecondaryEducation",
      "@type": "http://www.w3.org/2002/07/owl#Class",
      "inpackage": "OTHER_PACKAGE",
      "ap-definition-en": {
        "en": "Request for evidence proving the admission of the person (evidence subject) to a secondary education (EQF level 3) institution; note that although related to proof of enrolment it is not intrinsically equivalent to it."
