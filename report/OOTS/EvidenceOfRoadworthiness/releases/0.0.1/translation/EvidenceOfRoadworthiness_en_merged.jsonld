    {
      "@id": "http://data.europa.eu/m8g/Evidence",
      "@type": "http://www.w3.org/2002/07/owl#Class",
      "EA-Guid": "{F4749871-6F2D-4e38-B207-9CCACE847CF2}",
      "ap-definition-en": {
