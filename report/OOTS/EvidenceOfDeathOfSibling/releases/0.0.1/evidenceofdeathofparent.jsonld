, {
"@id": "http://www.w3.org/ns/person#placeOfDeath",
"@type": "http://www.w3.org/2002/07/owl#ObjectProperty",
"name": "placeOfDeath",
"inpackage": "UNKNOWN",
"ap-definition-en" : {"en": "The Location where the Person died"}, "usage" : {"en": "The Place of Birth and Place of Death are given using the Location class which is associated via the appropriate relationship. The Location Class has two properties: (1) the geographic name of the place, which is given as a string such as \"Amsterdam\" or \"Valetta\" and (2) an identifier, such as a geonames URI <a href=\"http:\/\/sws.geonames.org\/2759794\">http:\/\/sws.geonames.org\/2759794<\/a> (which identifies Amsterdam) or <a href=\"http:\/\/sws.geonames.org\/2562305\">http:\/\/sws.geonames.org\/2562305<\/a> (which identifies Valetta). The use of identifiers is preferred as these are unambiguous, however, public sector data typically uses simple names to record places and this is fully supported."}, "ap-label-en" : {"en": "place of death"}, "definition" : {"en": "The Location where the Person died"}, "label" : {"en": "place of death"},
