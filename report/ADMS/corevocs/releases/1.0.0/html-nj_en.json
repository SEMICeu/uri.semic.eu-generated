  "datatypes": [
    {
      "uri": "http://www.w3.org/1999/02/22-rdf-syntax-ns#langString",
      "name": "Text",
      "label": {
        "en": "Text"
      },
      "sort": "Text",
      "description": {
        "en": "The text data type is a combination of a string and a language identifier."
      },
      "usage": {
        "en": "It is useful for names and descriptions that are available in multiple languages. Where this is so, each version of the data should be included and each one associated with the relevant language identifier. RFC 3066 provides a commonly used set of identifiers for natural languages. This is the set recognised by UN/CEFACT and XML Schema.\r\nLanguages are represented by two character codes, optionally followed by a locale definition such as \"de\" meaning German and \"de-at\" meaning \"German as spoken in Austria.\""
      },
      "parents": [],
      "rawTags": {
        "uri": "http://www.w3.org/1999/02/22-rdf-syntax-ns#langString",
        "literal": "True",
        "label-en": "Text",
        "definition-en": "The text data type is a combination of a string and a language identifier.",
        "class-usage-scope": "datatype",
        "usageNote-en": "It is useful for names and descriptions that are available in multiple languages. Where this is so, each version of the data should be included and each one associated with the relevant language identifier. RFC 3066 provides a commonly used set of identifiers for natural languages. This is the set recognised by UN/CEFACT and XML Schema.\r\nLanguages are represented by two character codes, optionally followed by a locale definition such as \"de\" meaning German and \"de-at\" meaning \"German as spoken in Austria.\""
      },
      "properties": []
    },
