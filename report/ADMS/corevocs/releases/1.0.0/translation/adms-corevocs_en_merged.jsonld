    {
      "@id": "http://www.w3.org/1999/02/22-rdf-syntax-ns#langString",
      "@type": "http://www.w3.org/2002/07/owl#Class",
      "EA-Guid": "{085C46CB-1AA4-48a9-A25F-D320960C8C28}",
      "definition": {
        "en": "The text data type is a combination of a string and a language identifier."
      },
      "definition-en": {
        "en": "The text data type is a combination of a string and a language identifier."
      },
      "extra": {
        "EA-Guid": "{085C46CB-1AA4-48a9-A25F-D320960C8C28}",
        "EA-Name": "Text",
        "EA-Package": "DataTypes",
        "EA-Parents": "",
        "EA-Parents2": [],
        "EA-Type": "DATATYPE",
        "RawTags": [
          {
            "key": "uri",
            "note": "null",
            "value": "http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"
          },
          {
            "key": "literal",
            "note": "null",
            "value": "True"
          },
          {
            "key": "label-en",
            "note": "null",
            "value": "Text"
          },
          {
            "key": "definition-en",
            "note": "null",
            "value": "The text data type is a combination of a string and a language identifier."
          },
          {
            "key": "class-usage-scope",
            "note": "null",
            "value": "datatype"
          },
          {
            "key": "usageNote-en",
            "note": "It is useful for names and descriptions that are available in multiple languages. Where this is so, each version of the data should be included and each one associated with the relevant language identifier. RFC 3066 provides a commonly used set of identifiers for natural languages. This is the set recognised by UN/CEFACT and XML Schema.\r\nLanguages are represented by two character codes, optionally followed by a locale definition such as \"de\" meaning German and \"de-at\" meaning \"German as spoken in Austria.\"",
            "value": "NOTE"
          }
        ],
        "Scope": "NOTHING",
        "definition": {
          "en": "The text data type is a combination of a string and a language identifier."
        },
        "definition-en": {
          "en": "The text data type is a combination of a string and a language identifier."
        },
