    {
      "@id": "http://xmlns.com/foaf/0.1/Agent",
      "@type": "http://www.w3.org/2002/07/owl#Class",
      "EA-Guid": "{27085E1B-EF65-4e6c-93D2-5D0C0248B225}",
      "definition": {
        "en": "Entity that is able to carry out action."
      },
      "definition-en": {
        "en": "Entity that is able to carry out action."
      },
      "extra": {
        "EA-Guid": "{27085E1B-EF65-4e6c-93D2-5D0C0248B225}",
        "EA-Name": "Agent",
        "EA-Package": "foaf",
