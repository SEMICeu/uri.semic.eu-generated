      "name": "Identifier",
      "label": {
        "en": "Identifier"
      },
      "sort": "Identifier",
      "description": {
        "en": "A structured reference that identifies an entity."
      },
      "usage": {
        "en": "The Identifier class is based on the <a href=\"https://www.gs1.org/standards/edi/gs1-un-cefact-xml/2012\">UN/CEFACT</a> class of the same name and is defined under the ADMS namespace."
      },
