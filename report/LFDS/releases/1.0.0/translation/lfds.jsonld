        {
            "@id": "http://data.europa.eu/eli/ontology#is_realized_by",
            "@type": "http://www.w3.org/2002/07/owl#ObjectProperty",
            "name": "isRealizedBy",
            "inpackage": "OTHER_PACKAGE",
            "ap-definition-en": {
                "en": "Relates a work to an expression of this work in the form of a \"sequence of signs\" (typically alpha-numeric characters in a legal context)."
            },
            "ap-label-en": {
                "en": "is realized by"
