    {
      "@id": "http://data.europa.eu/2qy/lfds#DigitalSolution",
      "@type": "http://www.w3.org/2002/07/owl#Class",
      "EA-Guid": "{3D840B40-ED6C-4f45-AC9B-6FCF23C5C773}",
      "ap-definition-en": {
        "en": "A digital asset that refers to the development, evolutive maintenance, or use of specific digital platforms, tools, or applications."
      },
      "ap-label-en": {
        "en": "Digital Solution"
      },
      "definition": {
        "en": "A digital asset that refers to the development, evolutive maintenance, or use of specific digital platforms, tools, or applications."
      },
      "extra": {
        "EA-Guid": "{3D840B40-ED6C-4f45-AC9B-6FCF23C5C773}",
        "EA-Name": "DigitalSolution",
        "EA-Package": "lfds",
        "EA-Parents": "",
        "EA-Parents2": [],
        "EA-Type": "CLASS",
        "RawTags": [
          {
            "key": "uri",
            "note": "null",
            "value": "http://data.europa.eu/2qy/lfds#DigitalSolution"
          },
          {
            "key": "label-en",
            "note": "null",
            "value": "Digital Solution"
          },
          {
            "key": "definition-en",
            "note": "A digital asset that refers to the development, evolutive maintenance, or use of specific digital platforms, tools, or applications.",
            "value": "NOTE"
          },
          {
            "key": "usageNote-en",
            "note": "The definition of Digital Solution is aligned with the Digital Solution Category, which is used to categorise requirements of digital relevance. At the moment, it does not align with the definition of digital solution used in the digital-ready policymaking glossary, which covers all resources published on the Interoperable Europe Portal. In the LFDS context, not all assets published on the Interoperable Europe Portal are considered digital solutions; for example, data standards and specifications are covered by Section 2 - Data.",
            "value": "NOTE"
          }
        ],
        "Scope": "FULL_DEFINITON",
        "ap-codelist": "",
        "ap-definition-en": {
          "en": "A digital asset that refers to the development, evolutive maintenance, or use of specific digital platforms, tools, or applications."
        },
        "ap-label-en": {
          "en": "Digital Solution"
        },
        "ap-usageNote-en": "",
        "definition": {
          "en": "A digital asset that refers to the development, evolutive maintenance, or use of specific digital platforms, tools, or applications."
        },
        "label": {
          "en": "Digital Solution"
        },
        "parentclasses": "",
        "usage": {
          "en": "The definition of Digital Solution is aligned with the Digital Solution Category, which is used to categorise requirements of digital relevance. At the moment, it does not align with the definition of digital solution used in the digital-ready policymaking glossary, which covers all resources published on the Interoperable Europe Portal. In the LFDS context, not all assets published on the Interoperable Europe Portal are considered digital solutions; for example, data standards and specifications are covered by Section 2 - Data."
        }
      },
      "inpackage": "ACTIVE_PACKAGE",
      "label": {
        "en": "Digital Solution"
      },
      "name": "DigitalSolution",
      "parents": [],
      "usage": {
        "en": "The definition of Digital Solution is aligned with the Digital Solution Category, which is used to categorise requirements of digital relevance. At the moment, it does not align with the definition of digital solution used in the digital-ready policymaking glossary, which covers all resources published on the Interoperable Europe Portal. In the LFDS context, not all assets published on the Interoperable Europe Portal are considered digital solutions; for example, data standards and specifications are covered by Section 2 - Data."
      }
    },
