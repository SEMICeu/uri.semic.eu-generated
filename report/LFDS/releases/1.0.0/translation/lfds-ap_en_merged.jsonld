            "value": "NOTE"
          },
          {
            "key": "definition-en",
            "note": "A Public Service is a mandatory or discretionary set of activities performed, or able to be performed, by or on behalf of a public organisation, publicly funded and arise from public policy.",
            "value": "A Public Service is a mandatory or discretionary set of activities performed, or able to be performed, by or on behalf of a public organisation, publicly funded and arise from public policy."
          },
          {
            "key": "label-en",
            "note": "null",
            "value": "Public Service"
          },
          {
            "key": "uri",
