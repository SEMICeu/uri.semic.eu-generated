    {
      "@id": "http://data.europa.eu/eli/ontology#LegalExpression",
      "@type": "http://www.w3.org/2002/07/owl#Class",
      "EA-Guid": "{5458A214-C9AC-46d3-9CD7-6EDD780E1697}",
      "ap-definition-en": {
        "en": "The intellectual realisation of a legal resource in the form of a &quot;sequence of signs&quot; (typically alpha-numeric characters in a legal context).\r\nFor example, any version of the legal resource whose content is specified and different from others for any reason: language, versions, etc.;\r\n\r\nNote that ELI ontology accommodates different point of view on what should be considered a new legal resource, or a new legal expression of the same resource. Typically, a consolidated version can be viewed, in the context of ELI, either as separate legal resource (linked to original version and previous consolidated version using corresponding ELI relations), or as a different legal expression of the same legal resource."
      },
      "ap-label-en": {
        "en": "Legal Expression"
      },
      "definition": {
        "en": "The intellectual realisation of a legal resource in the form of a &quot;sequence of signs&quot; (typically alpha-numeric characters in a legal context).\r\nFor example, any version of the legal resource whose content is specified and different from others for any reason: language, versions, etc.;\r\n\r\nNote that ELI ontology accommodates different point of view on what should be considered a new legal resource, or a new legal expression of the same resource. Typically, a consolidated version can be viewed, in the context of ELI, either as separate legal resource (linked to original version and previous consolidated version using corresponding ELI relations), or as a different legal expression of the same legal resource."
      },
      "extra": {
        "EA-Guid": "{5458A214-C9AC-46d3-9CD7-6EDD780E1697}",
        "EA-Name": "LegalExpression",
        "EA-Package": "eli",
        "EA-Parents": "",
        "EA-Parents2": [],
        "EA-Type": "CLASS",
        "RawTags": [
          {
            "key": "definition-en",
            "note": "The intellectual realisation of a legal resource in the form of a &quot;sequence of signs&quot; (typically alpha-numeric characters in a legal context).\r\nFor example, any version of the legal resource whose content is specified and different from others for any reason: language, versions, etc.;\r\n\r\nNote that ELI ontology accommodates different point of view on what should be considered a new legal resource, or a new legal expression of the same resource. Typically, a consolidated version can be viewed, in the context of ELI, either as separate legal resource (linked to original version and previous consolidated version using corresponding ELI relations), or as a different legal expression of the same legal resource.",
            "value": "NOTE"
          },
          {
            "key": "label-en",
            "note": "null",
            "value": "Legal Expression"
          },
          {
            "key": "uri",
            "note": "null",
            "value": "http://data.europa.eu/eli/ontology#LegalExpression"
          }
        ],
        "Scope": "NOTHING",
        "ap-codelist": "",
        "ap-definition-en": {
          "en": "The intellectual realisation of a legal resource in the form of a &quot;sequence of signs&quot; (typically alpha-numeric characters in a legal context).\r\nFor example, any version of the legal resource whose content is specified and different from others for any reason: language, versions, etc.;\r\n\r\nNote that ELI ontology accommodates different point of view on what should be considered a new legal resource, or a new legal expression of the same resource. Typically, a consolidated version can be viewed, in the context of ELI, either as separate legal resource (linked to original version and previous consolidated version using corresponding ELI relations), or as a different legal expression of the same legal resource."
        },
        "ap-label-en": {
          "en": "Legal Expression"
        },
        "ap-usageNote-en": "",
        "definition": {
          "en": "The intellectual realisation of a legal resource in the form of a &quot;sequence of signs&quot; (typically alpha-numeric characters in a legal context).\r\nFor example, any version of the legal resource whose content is specified and different from others for any reason: language, versions, etc.;\r\n\r\nNote that ELI ontology accommodates different point of view on what should be considered a new legal resource, or a new legal expression of the same resource. Typically, a consolidated version can be viewed, in the context of ELI, either as separate legal resource (linked to original version and previous consolidated version using corresponding ELI relations), or as a different legal expression of the same legal resource."
        },
        "label": {
          "en": "Legal Expression"
        },
        "parentclasses": "",
        "usage": ""
      },
