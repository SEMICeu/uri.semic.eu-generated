            "value": "datatype"
          },
          {
            "key": "definition-en",
            "note": "null",
            "value": "The text data type is a combination of a string and a language identifier."
          },
          {
            "key": "label-en",
            "note": "null",
            "value": "Text"
          },
          {
            "key": "literal",
            "note": "null",
