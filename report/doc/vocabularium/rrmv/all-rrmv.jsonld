          "en": "A portion of legal source expression including a mandate that produces at least one Action."
        },
        "usageNote-en": "",
        "equivalent": "",
        "subclass": "",
        "subclass1": "",
        "sameAs": "",
        "RawTags": [
          {
            "key": "definition-en",
            "value": "A portion of legal source expression including a mandate that produces at least one Action.",
            "note": "null"
          },
          {
            "key": "label-en",
            "value": "Requirement",
            "note": "null"
          },
          {
            "key": "class-usage-scope",
            "value": "main",
            "note": "null"
          },
          {
            "key": "ap-usageNote-en",
            "value": "NOTE",
            "note": "A Requirement represents a normative provision within a legal text that mandates, permits, or prohibits specific actions. It typically corresponds to an article, paragraph, or clause that establishes obligations for identified agents. For example, Article 26(2) of Regulation (EU) 2018/1999 constitutes a reporting Requirement because it mandates Member States to submit greenhouse gas inventories to the Commission. Each Requirement is linked to the specific portion(s) of the legal text through has URI and must produce at least one Action representing the mandated activity."
          }
        ],
        "Scope": "NOTHING"
      },
      "name": "Requirement"
    },
