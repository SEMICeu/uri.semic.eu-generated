    {
      "@id": "http://data.europa.eu/eli/ontology#Expression",
      "@type": "http://www.w3.org/2002/07/owl#Class",
      "inpackage": "OTHER_PACKAGE",
      "label-en": {
        "en": "Expression"
      },
      "definition-en": {
        "en": "The intellectual realisation of a Work in the form of identifiable immaterial objects, such as, but not limited to, text.\r\nThe substance of Expression is signs.\r\nAn Expression cannot exist without a physical carrier but do not depend on a specific physical carrier and can exist on one or more carriers simultaneously."
      },
