    {
      "@id": "http://www.w3.org/2006/vcard/ns#Kind",
      "@type": "http://www.w3.org/2002/07/owl#Class",
      "inpackage": "OTHER_PACKAGE",
      "ap-definition-en": {
        "en": "A description following the vCard specification, e.g. to provide telephone number and e-mail address for a contact point."
      },
      "ap-label-en": {
        "en": "Kind"
