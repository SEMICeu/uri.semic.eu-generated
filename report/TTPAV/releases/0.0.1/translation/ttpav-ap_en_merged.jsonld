        },
        "usage": {
          "en": "Provide the name under which the controller, legal entity, sponsor, or paying entity is legally registered.\nThe legal name is different from the alternative (trade) name which is a pseudonym used by companies that do not operate under their registered company name.\nA business might have more than one legal name, particularly in countries with more than one official language. In such cases, and where the encoding technology allows, the language of the string should be identified."
        }
      },
      "generalization": [],
      "inpackage": "OTHER_PACKAGE",
      "label": {
        "en": "legal name"
      },
      "maxCardinality": "*",
      "minCardinality": "0",
      "name": "legalName",
      "range": [
        {
          "EA-GUID": "{31427F3B-588A-40dd-968A-ED4472D160DC}",
          "EA-Name": "Text",
          "EA-Package": "Core Vocabulary",
          "uri": "http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"
        }
      ],
      "usage": {
        "en": "Provide the name under which the controller, legal entity, sponsor, or paying entity is legally registered.\nThe legal name is different from the alternative (trade) name which is a pseudonym used by companies that do not operate under their registered company name.\nA business might have more than one legal name, particularly in countries with more than one official language. In such cases, and where the encoding technology allows, the language of the string should be identified."
      }
    },
    {
      "@id": "http://www.w3.org/ns/legal#LegalEntity",
      "@type": "http://www.w3.org/2002/07/owl#ObjectProperty",
      "EA-Guid": "{C32B2ECA-723C-4f03-956D-29E47BCB7D82}",
      "ap-definition-en": {
        "en": "A self-employed person, company, or organization that has legal rights and obligations."
      },
      "ap-label-en": {
        "en": "legal entity"
      },
      "codelist": [],
      "definition": {
        "en": "A self-employed person, company, or organization that has legal rights and obligations."
      },
      "domain": [
        {
          "EA-Name": "Transparency Notice",
          "uri": "http://example.org/TransparencyNotice"
        }
      ],
      "extra": {
        "DestRoleTags": [
          {
            "key": "package",
            "note": "Core Business",
            "value": "NOTE"
          },
          {
            "key": "definition-en",
            "note": "A self-employed person, company, or organization that has legal rights and obligations.",
            "value": "NOTE"
          },
          {
            "key": "uri",
            "note": "http://www.w3.org/ns/legal#LegalEntity",
            "value": "NOTE"
          },
          {
            "key": "label-en",
            "note": "legal entity",
            "value": "NOTE"
          },
          {
            "key": "usageNote-en",
            "note": "NOTE$ea_notes=A Legal Entity able to transact business, typically registered with a body able to confer legal status such as a national business register. It is able to trade, is legally liable for its actions, accounts, tax affairs etc. This makes Legal Entities distinct from the concept of organisations or groups. Many organisations exist that are not Legal Entities, yet to the outside world they have staff, hierarchies, locations etc. Other organisations exist that are an umbrella for several Legal Entities (universities are often good examples of this). This vocabulary is concerned solely with registered Legal Entities and does not attempt to cover all possible trading bodies.",
            "value": "NOTE"
          }
        ],
