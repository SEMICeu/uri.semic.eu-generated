      "@type": "http://www.w3.org/2002/07/owl#Class",
      "EA-Guid": "{D7465C4B-0B62-41dc-808A-8F0E04B79276}",
      "ap-definition-en": {
        "en": "A self-employed person,company,or organization that has legal rights and obligations."
      },
      "ap-label-en": {
        "en": "Legal Entity"
      },
      "definition": {
        "en": "A self-employed person,company,or organization that has legal rights and obligations."
      },
      "extra": {
        "EA-Guid": "{D7465C4B-0B62-41dc-808A-8F0E04B79276}",
        "EA-Name": "LegalEntity",
        "EA-Package": "Core Business",
        "EA-Parents": "",
        "EA-Parents2": [],
        "EA-Type": "CLASS",
        "RawTags": [
          {
            "key": "definition-en",
            "note": "A legal entity able to transact business, typically registered with a body able to confer legal status such as a national business register.\r\nIn RDF terms, a legal entity is a sub class of dcterms:Agent and foaf:Agent.\r\nIn XML terms, this is equivalent to the UN/CEFACT term 'Business profile",
            "value": "A self-employed person,company,or organization that has legal rights and obligations."
          },
          {
            "key": "label-en",
            "note": "null",
            "value": "Legal Entity"
          },
          {
            "key": "parentURI",
            "note": "null",
            "value": "http://www.w3.org/ns/org#FormalOrganization"
          },
          {
            "key": "uri",
            "note": "null",
            "value": "http://www.w3.org/ns/legal#LegalEntity"
          },
          {
            "key": "usageNote-en",
            "note": "Use this class to represent any legal entity involved in the context of a political advertisement, including the sponsor, the paying entity, or the legal entity ultimately controlling the sponsor. This class supports the requirements for transparency notices under EU Regulation 2024/900, which mandate disclosure of the identity, contact details, and registration information for all such entities.",
            "value": "NOTE"
          }
        ],
        "Scope": "NOTHING",
        "ap-codelist": "",
