        "EA-Name": "fullAddress",
        "EA-Package": "Core Location",
        "EA-Range": "Text",
        "EA-Type": "attribute",
        "RangeData": {
          "EA-GUID": "{31427F3B-588A-40dd-968A-ED4472D160DC}",
          "EA-Name": "Text",
          "EA-Package": "Core Vocabulary",
          "uri": "http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"
        },
        "RawTags": [
          {
            "key": "uri",
            "note": "null",
            "value": "http://www.w3.org/ns/locn#fullAddress"
          },
          {
            "key": "label-en",
            "note": "null",
            "value": "full address"
          },
          {
            "key": "definition-en",
            "note": "null",
            "value": "The complete address written as a string."
          },
          {
            "key": "usageNote-en",
            "note": "Use of this property is recommended as it will not suffer any misunderstandings that might arise through the breaking up of an address into its component parts. This property is analogous to vCard's label property but with two important differences: (1) formatting is not assumed so that, unlike vCard label, it may not be suitable to print this on an address label, (2) vCard's label property has a domain of vCard Address; the fullAddress property has no such restriction. An example of a full address is \"Champ de Mars, 5 Avenue Anatole France, 75007 Paris, France\".",
            "value": "NOTE"
          }
        ],
        "Scope": "NOTHING",
        "ap-codelist": "",
        "ap-definition-en": {
          "en": "The complete address written as a string."
        },
        "ap-label-en": {
          "en": "full address"
        },
        "ap-usageNote-en": "",
        "definition": {
          "en": "The complete address written as a string."
        },
        "label": {
          "en": "full address"
        },
        "usage": {
          "en": "Use of this property is recommended as it will not suffer any misunderstandings that might arise through the breaking up of an address into its component parts. This property is analogous to vCard's label property but with two important differences: (1) formatting is not assumed so that, unlike vCard label, it may not be suitable to print this on an address label, (2) vCard's label property has a domain of vCard Address; the fullAddress property has no such restriction. An example of a full address is \"Champ de Mars, 5 Avenue Anatole France, 75007 Paris, France\"."
        }
      },
      "generalization": [],
      "inpackage": "OTHER_PACKAGE",
      "label": {
        "en": "full address"
