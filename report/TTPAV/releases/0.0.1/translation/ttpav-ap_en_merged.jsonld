    {
      "@id": "http://www.w3.org/ns/locn#addressId",
      "@type": "http://www.w3.org/2002/07/owl#DatatypeProperty",
      "EA-Guid": "{197480FD-EC14-4b45-B1EE-043D54707283}",
      "ap-definition-en": {
        "en": "A globally unique identifier for each instance of an Address."
      },
      "ap-label-en": {
        "en": "address ID"
      },
      "codelist": [],
      "definition": {
        "en": "A globally unique identifier for each instance of an Address."
      },
      "domain": [
        {
          "EA-Name": "Address",
          "uri": "http://www.w3.org/ns/locn#Address"
        }
      ],
      "extra": {
        "EA-Domain": "Address",
        "EA-Domain-Guid": "{5B14E506-A68C-4c9b-8238-952096E7B472}",
        "EA-Guid": "{197480FD-EC14-4b45-B1EE-043D54707283}",
        "EA-Name": "addressID",
        "EA-Package": "Core Location",
        "EA-Range": "Literal",
        "EA-Type": "attribute",
        "RangeData": {
          "EA-Name": "Literal",
          "EA-Package": "",
          "uri": "http://www.w3.org/2000/01/rdf-schema#Literal"
        },
        "RawTags": [
          {
            "key": "usageNote-en",
            "note": "The concept of adding a globally unique identifier for each instance of an address is a crucial part of the INSPIRE data spec. A number of EU countries have already implemented an ID (a UUID) in their Address Register/gazetteer, among them Denmark. OASIS xAL also includes an address identifier. It is the address Identifier that allows an address to be represented in a format other than INSPIRE whilst remaining conformant to the Core Vocabulary.\r\n<br/><br/>\r\nThe <a href=\"https://knowledge-base.inspire.ec.europa.eu/index_en\">INSPIRE</a> method of representing addresses is very detailed, designed primarily for use in databases of addresses. Whilst data that is published in full conformance with the INSPIRE data structure can be made available using the<a href=\"https://semiceu.github.io/Core-Location-Vocabulary/\">Core Location Vocabulary</a> the reverse is not true since the Core Vocabulary allows much greater flexibility.\r\n<br/><br/>\r\nMany datasets that include address data as one piece of information about something else are likely to have that data in simpler formats. These might be tailored to the specific need of the dataset, follow a national norm, or make use of a standard like vCard.\r\n<br/><br/>\r\nTo provide maximum flexibility in the Core Vocabulary, whilst remaining interoperable with <a href=\"https://joinup.ec.europa.eu/collection/inspire/solution/inspire-data-specifications-addresses-guidelines-v301\">INSPIRE Address Guidelines</a> (which EU Member States are obliged to use), the  Core Location Vocabulary provides the extra property of full address and makes use of INSPIRE's addressID.\r\n\r\n",
            "value": "NOTE"
          },
          {
            "key": "uri",
            "note": "null",
            "value": "http://www.w3.org/ns/locn#addressId"
          },
          {
            "key": "label-en",
            "note": "null",
            "value": "address ID"
          },
          {
            "key": "definition-en",
            "note": "null",
            "value": "A globally unique identifier for each instance of an Address."
          }
        ],
        "Scope": "NOTHING",
        "ap-codelist": "",
        "ap-definition-en": {
          "en": "A globally unique identifier for each instance of an Address."
        },
        "ap-label-en": {
          "en": "address ID"
        },
        "ap-usageNote-en": "",
        "definition": {
          "en": "A globally unique identifier for each instance of an Address."
        },
        "label": {
          "en": "address ID"
        },
        "usage": {
          "en": "The concept of adding a globally unique identifier for each instance of an address is a crucial part of the INSPIRE data spec. A number of EU countries have already implemented an ID (a UUID) in their Address Register/gazetteer, among them Denmark. OASIS xAL also includes an address identifier. It is the address Identifier that allows an address to be represented in a format other than INSPIRE whilst remaining conformant to the Core Vocabulary.\r\n<br/><br/>\r\nThe <a href=\"https://knowledge-base.inspire.ec.europa.eu/index_en\">INSPIRE</a> method of representing addresses is very detailed, designed primarily for use in databases of addresses. Whilst data that is published in full conformance with the INSPIRE data structure can be made available using the<a href=\"https://semiceu.github.io/Core-Location-Vocabulary/\">Core Location Vocabulary</a> the reverse is not true since the Core Vocabulary allows much greater flexibility.\r\n<br/><br/>\r\nMany datasets that include address data as one piece of information about something else are likely to have that data in simpler formats. These might be tailored to the specific need of the dataset, follow a national norm, or make use of a standard like vCard.\r\n<br/><br/>\r\nTo provide maximum flexibility in the Core Vocabulary, whilst remaining interoperable with <a href=\"https://joinup.ec.europa.eu/collection/inspire/solution/inspire-data-specifications-addresses-guidelines-v301\">INSPIRE Address Guidelines</a> (which EU Member States are obliged to use), the  Core Location Vocabulary provides the extra property of full address and makes use of INSPIRE's addressID.\r\n\r\n"
        }
      },
      "generalization": [],
      "inpackage": "OTHER_PACKAGE",
      "label": {
        "en": "address ID"
      },
      "maxCardinality": "*",
      "minCardinality": "0",
      "name": "addressId",
      "range": [
        {
          "EA-Name": "Literal",
          "EA-Package": "",
          "uri": "http://www.w3.org/2000/01/rdf-schema#Literal"
        }
      ],
      "usage": {
        "en": "The concept of adding a globally unique identifier for each instance of an address is a crucial part of the INSPIRE data spec. A number of EU countries have already implemented an ID (a UUID) in their Address Register/gazetteer, among them Denmark. OASIS xAL also includes an address identifier. It is the address Identifier that allows an address to be represented in a format other than INSPIRE whilst remaining conformant to the Core Vocabulary.\r\n<br/><br/>\r\nThe <a href=\"https://knowledge-base.inspire.ec.europa.eu/index_en\">INSPIRE</a> method of representing addresses is very detailed, designed primarily for use in databases of addresses. Whilst data that is published in full conformance with the INSPIRE data structure can be made available using the<a href=\"https://semiceu.github.io/Core-Location-Vocabulary/\">Core Location Vocabulary</a> the reverse is not true since the Core Vocabulary allows much greater flexibility.\r\n<br/><br/>\r\nMany datasets that include address data as one piece of information about something else are likely to have that data in simpler formats. These might be tailored to the specific need of the dataset, follow a national norm, or make use of a standard like vCard.\r\n<br/><br/>\r\nTo provide maximum flexibility in the Core Vocabulary, whilst remaining interoperable with <a href=\"https://joinup.ec.europa.eu/collection/inspire/solution/inspire-data-specifications-addresses-guidelines-v301\">INSPIRE Address Guidelines</a> (which EU Member States are obliged to use), the  Core Location Vocabulary provides the extra property of full address and makes use of INSPIRE's addressID.\r\n\r\n"
      }
    },
