    {
      "@id": "http://www.w3.org/ns/locn#locatorName",
      "@type": "http://www.w3.org/2002/07/owl#DatatypeProperty",
      "EA-Guid": "{2A82353F-165E-4b8d-87EA-6134598C3F9F}",
      "ap-definition-en": {
        "en": "Proper noun(s) applied to the real world entity identified by the locator. The locator name could be the name of the property or complex, of the building or part of the building, or it could be the name of a room inside a building."
      },
      "ap-label-en": {
        "en": "locator name"
      },
      "codelist": [],
      "definition": {
        "en": "Proper noun(s) applied to the real world entity identified by the locator. The locator name could be the name of the property or complex, of the building or part of the building, or it could be the name of a room inside a building."
      },
      "domain": [
        {
          "EA-Name": "Address",
          "uri": "http://www.w3.org/ns/locn#Address"
        }
      ],
      "extra": {
        "EA-Domain": "Address",
        "EA-Domain-Guid": "{5B14E506-A68C-4c9b-8238-952096E7B472}",
        "EA-Guid": "{2A82353F-165E-4b8d-87EA-6134598C3F9F}",
        "EA-Name": "locatorName",
        "EA-Package": "Core Location",
        "EA-Range": "Text",
        "EA-Type": "attribute",
        "RangeData": {
          "EA-GUID": "{31427F3B-588A-40dd-968A-ED4472D160DC}",
          "EA-Name": "Text",
          "EA-Package": "Core Vocabulary",
          "uri": "http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"
        },
        "RawTags": [
          {
            "key": "usageNote-en",
            "note": "The locator name could be the name of the property or complex, of the building or part of the building, or it could be the name of a room inside a building.\r\n<br/><br/>\r\nThe key difference between a locator designator and a locator name is that the latter is a proper name and is unlikely to include digits. For example, \"Shumann, Berlaymont\" is a meeting room within the European Commission headquarters for which locator name is more appropriate than locator.",
            "value": "NOTE"
          },
          {
            "key": "uri",
            "note": "null",
            "value": "http://www.w3.org/ns/locn#locatorName"
          },
          {
            "key": "label-en",
            "note": "null",
            "value": "locator name"
          },
          {
            "key": "definition-en",
            "note": "null",
            "value": "Proper noun(s) applied to the real world entity identified by the locator. The locator name could be the name of the property or complex, of the building or part of the building, or it could be the name of a room inside a building."
          }
        ],
        "Scope": "NOTHING",
        "ap-codelist": "",
        "ap-definition-en": {
          "en": "Proper noun(s) applied to the real world entity identified by the locator. The locator name could be the name of the property or complex, of the building or part of the building, or it could be the name of a room inside a building."
        },
        "ap-label-en": {
          "en": "locator name"
        },
        "ap-usageNote-en": "",
        "definition": {
          "en": "Proper noun(s) applied to the real world entity identified by the locator. The locator name could be the name of the property or complex, of the building or part of the building, or it could be the name of a room inside a building."
        },
        "label": {
          "en": "locator name"
        },
        "usage": {
          "en": "The locator name could be the name of the property or complex, of the building or part of the building, or it could be the name of a room inside a building.\r\n<br/><br/>\r\nThe key difference between a locator designator and a locator name is that the latter is a proper name and is unlikely to include digits. For example, \"Shumann, Berlaymont\" is a meeting room within the European Commission headquarters for which locator name is more appropriate than locator."
        }
      },
      "generalization": [],
      "inpackage": "OTHER_PACKAGE",
      "label": {
        "en": "locator name"
      },
