    {
      "@id": "http://www.w3.org/ns/legal#LegalEntity",
      "@type": "http://www.w3.org/2002/07/owl#Class",
      "EA-Guid": "{D7465C4B-0B62-41dc-808A-8F0E04B79276}",
      "ap-definition-en": {
        "en": "A self-employed person,company,or organization that has legal rights and obligations."
      },
      "ap-label-en": {
        "en": "Legal Entity"
      },
      "definition": {
        "en": "A self-employed person,company,or organization that has legal rights and obligations."
      },
      "extra": {
        "EA-Guid": "{D7465C4B-0B62-41dc-808A-8F0E04B79276}",
        "EA-Name": "LegalEntity",
        "EA-Package": "Core Business",
        "EA-Parents": "",
        "EA-Parents2": [],
        "EA-Type": "CLASS",
        "RawTags": [
          {
            "key": "class-usage-scope",
            "note": "null",
            "value": "main"
          },
          {
            "key": "definition-en",
            "note": "A legal entity able to transact business, typically registered with a body able to confer legal status such as a national business register.\r\nIn RDF terms, a legal entity is a sub class of dcterms:Agent and foaf:Agent.\r\nIn XML terms, this is equivalent to the UN/CEFACT term 'Business profile",
            "value": "A self-employed person,company,or organization that has legal rights and obligations."
          },
          {
            "key": "label-en",
            "note": "null",
            "value": "Legal Entity"
          },
          {
            "key": "parentURI",
            "note": "null",
            "value": "http://www.w3.org/ns/org#FormalOrganization"
          },
          {
            "key": "uri",
            "note": "null",
            "value": "http://www.w3.org/ns/legal#LegalEntity"
          },
          {
            "key": "usageNote-en",
            "note": "A Legal Entity able to transact business, typically registered with a body able to confer legal status such as a national business register. It is able to trade, is legally liable for its actions, accounts, tax affairs etc. This makes Legal Entities distinct from the concept of organisations or groups. Many organisations exist that are not Legal Entities, yet to the outside world they have staff, hierarchies, locations etc. Other organisations exist that are an umbrella for several Legal Entities (universities are often good examples of this). This vocabulary is concerned solely with registered Legal Entities and does not attempt to cover all possible trading bodies.",
            "value": "NOTE"
          }
        ],
        "Scope": "NOTHING",
        "ap-codelist": "",
        "ap-definition-en": {
          "en": "A self-employed person,company,or organization that has legal rights and obligations."
        },
        "ap-label-en": {
          "en": "Legal Entity"
        },
        "ap-usageNote-en": "",
        "definition": {
          "en": "A self-employed person,company,or organization that has legal rights and obligations."
        },
        "label": {
          "en": "Legal Entity"
        },
        "parentclasses": "",
        "usage": {
          "en": "A Legal Entity able to transact business, typically registered with a body able to confer legal status such as a national business register. It is able to trade, is legally liable for its actions, accounts, tax affairs etc. This makes Legal Entities distinct from the concept of organisations or groups. Many organisations exist that are not Legal Entities, yet to the outside world they have staff, hierarchies, locations etc. Other organisations exist that are an umbrella for several Legal Entities (universities are often good examples of this). This vocabulary is concerned solely with registered Legal Entities and does not attempt to cover all possible trading bodies."
        }
      },
      "inpackage": "OTHER_PACKAGE",
