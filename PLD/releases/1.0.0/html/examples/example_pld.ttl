<https://www.legifrance.gouv.fr/juri/id/JURITEXT000049774997> cdm:case-law_ecli "ECLI:FR:CCASS:2024:CR00903" ;
	cdm:case-law_national_decision_internal_identifier "22-81.808" ;
	cdm:case-law_delivered_by_court_national [
		rdf:type cdm:court_national ;
		cdm:court_national_name "Cour de cassation"@fr ;
		cdm:court_national_has_type_concept_class_court_national <http://publications.europa.eu/resource/authority/court-type/NAT_COURT_SUPREME> ;
	] ;
