@prefix dct: <http://purl.org/dc/terms/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix shacl: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix r5r: <http://data.europa.eu/r5r/> .

@prefix : <https://semiceu.github.io/DCAT-AP/drafts/3.0.1-hvd#>.


<https://semiceu.github.io/DCAT-AP/drafts/3.0.1-hvd> rdfs:member 
          :DatasetShapeCV ,
          :CatalogShapeCV,
          :DistributionShapeCV,
          :DataServiceShapeCVr, 
          :DatasetSeriesShapeCV .

:HVDCategoryRestriction
    a shacl:NodeShape ;
    rdfs:comment "HVD Category restriction" ;
    rdfs:label "HVD Category restriction" ;
    shacl:property [
        shacl:hasValue <http://data.europa.eu/bna/asd487ae75> ;
        shacl:minCount 1 ;
        shacl:nodeKind shacl:IRI ;
        shacl:path skos:inScheme
    ] .

:EULicenceRestriction
    a shacl:NodeShape ;
    rdfs:comment "EU Licence restriction" ;
    rdfs:label "EU Licence restriction" ;
    shacl:property [
        shacl:hasValue <http://publications.europa.eu/resource/authority/licence> ;
        shacl:minCount 1 ;
        shacl:nodeKind shacl:IRI ;
        shacl:path skos:inScheme
    ] .

:DatasetShapeCV
    a shacl:NodeShape ;
    shacl:property [
        shacl:node :HVDCategoryRestriction ;
        shacl:nodeKind shacl:IRI ;
        shacl:path r5r:hvdCategory
    ] ;
    shacl:targetClass dcat:Dataset.


:DataServiceShapeCV
    a shacl:NodeShape ;
    shacl:property [
        shacl:node :HVDCategoryRestriction ;
        shacl:nodeKind shacl:IRI ;
        shacl:path r5r:hvdCategory
    ] ; 
    shacl:targetClass dcat:DataService.


:DatasetSeriesShapeCV
    a shacl:NodeShape ;
    shacl:property [
        shacl:node :HVDCategoryRestriction ;
        shacl:nodeKind shacl:IRI ;
        shacl:path r5r:hvdCategory
    ] ; 
    shacl:targetClass dcat:DatasetSeries.

:LicenseDocumentShapeCV
    a shacl:NodeShape ;
    shacl:property [
        shacl:node :EULicenceRestriction ;
        shacl:nodeKind shacl:IRI ;
        shacl:path skos:narrowMatch
    ] ;
    shacl:property [
        shacl:node :EULicenceRestriction ;
        shacl:nodeKind shacl:IRI ;
        shacl:path skos:exactMatch
    ] ; 
    shacl:targetClass dct:LicenseDocument.