@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix locn: <http://www.w3.org/ns/locn#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix cv: <http://data.europa.eu/m8g/> .
@prefix elm: <http://data.europa.eu/snb/model/elm/> .
@prefix ex: <http://example.com/> .
@prefix legal: <http://www.w3.org/ns/legal#> .
@prefix person: <http://www.w3.org/ns/person#> .
@prefix sdg: <http://data.europa.eu/p4s/> .

ex:evidenceof1 sdg:hasAttributeSet ex:attributeSet1 ;
	dcterms:subject ex:person1 ;
	dcterms:requires ex:admission1 ;
	a sdg:EvidenceOfCertificateAdmissionSecondaryEducation .

ex:person1 foaf:givenName "René François Ghislain"@fr ;
	foaf:familyName "Magritte"@fr ;
	a person:Person .

ex:admission1 elm:duration "P5Y"^^xsd:duration ;
	elm:endDate "2026-03-05T09:00:00"^^xsd:dateTime ;
	elm:startDate "2021-03-05T09:00:00"^^xsd:dateTime ;
	legal:legalName "OOTS University"@en ;
	elm:LearningOpportunity "OOTS Master Class"@en ;
	a sdg:Admission .
