@prefix cv: <http://data.europa.eu/m8g/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix ex: <http://example.com/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix locn: <http://www.w3.org/ns/locn#> .
@prefix person: <http://www.w3.org/ns/person#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sdg: <http://data.europa.eu/p4s/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:evidenceofcitizenship1 sdg:hasAttributeSet ex:attributeSet1 ;
	dct:subject ex:person1 ;
	sdg:hasCitizenship ex:citizenship1 ;
	a sdg:EvidenceOfCitizenship .

ex:attributeSet1 sdg:hasAttribute ex:attribute1, ex:attribute2 ;
	a sdg:AttributeSet .

ex:attribute1 rdfs:label "IssuingDate" ;
	rdf:value "2025-04-12"^^xsd:date ;
	a sdg:Attribute .

ex:attribute2 rdfs:label "IssuingAuthority" ;
	rdf:value "Dienst Burgerzaken van de Gemeente Amsterdam"@nl ;
	a sdg:Attribute .

ex:person1 foaf:givenName "Pieter"@nl ;
	foaf:familyName "De Vries"@nl ;
	cv:birthDate "1985-09-23"^^cv:genericDate ;
	a person:Person .

ex:citizenship1 dct:issued "2010-03-01"^^cv:genericDate ;
	person:citizenship ex:jurisdiction1 ;
	sdg:hasAttributeSet ex:attributeSet2 ;
	a sdg:Citizenship .

ex:jurisdiction1 rdfs:label "Koninkrijk der Nederlanden"@nl ;
	a dct:Jurisdiction .

ex:attributeSet2 sdg:hasAttribute ex:attribute3, ex:attribute4 ;
	a sdg:AttributeSet .

ex:attribute3 rdfs:label "CitizenshipStatus" ;
	rdf:value "Actief"@nl ;
	a sdg:Attribute .

ex:attribute4 rdfs:label "AcquisitionMode" ;
	rdf:value "Naturalisatie"@nl ;
	a sdg:Attribute .