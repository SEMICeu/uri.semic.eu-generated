@prefix cv: <http://data.europa.eu/m8g/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix ex: <http://example.com/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix locn: <http://www.w3.org/ns/locn#> .
@prefix person: <http://www.w3.org/ns/person#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sdg: <http://data.europa.eu/p4s/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:evidenceofdeathofchild1 sdg:hasAttributeSet ex:attributeSet1 ;
	dct:subject ex:person1 ;
	sdg:hasDeath ex:death1 ;
	sdg:hasChild ex:person2 ;
	a sdg:EvidenceOfDeathOfChild .

ex:attributeSet1 sdg:hasAttribute ex:attribute1, ex:attribute2 ;
	a sdg:AttributeSet .

ex:attribute1 rdfs:label "IssuingDate" ;
	rdf:value "2024-12-03"^^xsd:date ;
	a sdg:Attribute .

ex:attribute2 rdfs:label "IssuingAuthority" ;
	rdf:value "Standesamt der Stadt Wien"@de ;
	a sdg:Attribute .

ex:person1 foaf:givenName "Katharina"@de ;
	foaf:familyName "Schindler"@de ;
	a person:Person .

ex:person2 foaf:givenName "Lukas"@de ;
	foaf:familyName "Schindler"@de ;
	cv:birthDate "2016-04-18"^^cv:genericDate ;
	a person:Person .

ex:death1 cv:deathDate "2024-11-15"^^cv:genericDate ;
	person:placeOfDeath ex:location1 ;
	person:countryOfDeath ex:location2 ;
	sdg:hasAttributeSet ex:attributeSet2 ;
	a sdg:Death .

ex:attributeSet2 sdg:hasAttribute ex:attribute3, ex:attribute4 ;
	a sdg:AttributeSet .

ex:attribute3 rdfs:label "TimeOfDeath" ;
	rdf:value "14:30:00"^^xsd:time ;
	a sdg:Attribute .

ex:attribute4 rdfs:label "CauseOfDeath" ;
	rdf:value "Verkehrsunfall"@de ;
	a sdg:Attribute .

ex:location1 locn:geographicName "Wien"@de ;
	a dct:Location .

ex:location2 locn:geographicName "AT"@de ;
	a dct:Location .