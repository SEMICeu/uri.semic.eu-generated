@prefix cv: <http://data.europa.eu/m8g/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix ex: <http://example.com/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix locn: <http://www.w3.org/ns/locn#> .
@prefix person: <http://www.w3.org/ns/person#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sdg: <http://data.europa.eu/p4s/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:evidenceofdisability1 sdg:hasAttributeSet ex:attributeSet1 ;
	dct:subject ex:person1 ;
	sdg:hasDisability ex:disability1 ;
	a sdg:EvidenceOfDisability .

ex:attributeSet1 sdg:hasAttribute ex:attribute1, ex:attribute2 ;
	a sdg:AttributeSet .

ex:attribute1 rdfs:label "IssuingDate" ;
	rdf:value "2025-01-10"^^xsd:date ;
	a sdg:Attribute .

ex:attribute2 rdfs:label "IssuingAuthority" ;
	rdf:value "Instituto de Mayores y Servicios Sociales de Madrid"@es ;
	a sdg:Attribute .

ex:person1 foaf:givenName "Alejandro"@es ;
	foaf:familyName "García López"@es ;
	a person:Person .

ex:disability1 sdg:dateOfIssueOfDisabilityStatus "2023-06-15"^^cv:genericDate ;
	sdg:dateOfExipryOfDisabilityStatus "2028-06-15"^^cv:genericDate ;
	sdg:typeOfDisability ex:disabilityType1 ;
	sdg:disabilityDegree ex:disabilityDegree1 ;
	sdg:hasAttributeSet ex:attributeSet2 ;
	a sdg:Disability .

ex:disabilityType1 skos:prefLabel "Discapacidad física"@es ;
	a skos:Concept .

ex:disabilityDegree1 skos:prefLabel "65%"@es ;
	a skos:Concept .

ex:attributeSet2 sdg:hasAttribute ex:attribute3, ex:attribute4 ;
	a sdg:AttributeSet .

ex:attribute3 rdfs:label "AssessmentDate" ;
	rdf:value "2023-05-20"^^xsd:date ;
	a sdg:Attribute .

ex:attribute4 rdfs:label "AssessmentAuthority" ;
	rdf:value "Centro de Valoración y Orientación de Madrid"@es ;
	a sdg:Attribute .