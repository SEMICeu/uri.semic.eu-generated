    <rdfs:comment xml:lang="en">Key party responsible for gathering information and conducting research [[ISO-19115]].</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.w3.org/2000/01/rdf-schema#Resource"/>
    <rdfs:range rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://data.europa.eu/930/processor">
