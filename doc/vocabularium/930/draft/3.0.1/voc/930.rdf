    <rdfs:label xml:lang="en">custodian</rdfs:label>
    <rdfs:comment xml:lang="en">Party that accepts accountability and responsibility for the data and ensures appropriate care and maintenance of the resource [[ISO-19115]].</rdfs:comment>
