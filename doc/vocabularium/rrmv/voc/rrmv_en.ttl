@prefix dc: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schemas: <https://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://data.europa.eu/2qy/rrmv#hasFunction> a owl:ObjectProperty;
  rdfs:label "has function"@en;
  rdfs:comment "The function played by the TemporalEntitySpecification, such as a deadline or a validity period."@en;
  rdfs:domain <http://data.europa.eu/2qy/rrmv#TemporalEntitySpec>;
  rdfs:isDefinedBy <http://data.europa.eu/2qy/rrmv>;
  rdfs:range <http://data.europa.eu/2qy/rrmv#TemporalFunction>;
  skos:scopeNote "For instance as deadline, moment of entering into force, etc."@en .

<http://data.europa.eu/2qy/rrmv#hasType> a owl:ObjectProperty;
  rdfs:label "has type"@en;
  rdfs:comment "indicates the kind of the resource"@en;
  rdfs:domain <http://data.europa.eu/2qy/rrmv#Role>,
    <http://data.europa.eu/2qy/rrmv#ActionResult>;
  rdfs:isDefinedBy <http://data.europa.eu/2qy/rrmv>;
  rdfs:range <http://data.europa.eu/2qy/rrmv#RoleType>,
    <http://data.europa.eu/2qy/rrmv#ResultType> .

