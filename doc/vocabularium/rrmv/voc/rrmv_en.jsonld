    {
      "@id": "http://data.europa.eu/2qy/rrmv#hasFunction",
      "@type": "http://www.w3.org/2002/07/owl#ObjectProperty",
      "label": {
        "en": "has function"
      },
      "definition": {
        "en": "The function played by the TemporalEntitySpecification, such as a deadline or a validity period."
      },
      "usage": {
        "en": "For instance as deadline, moment of entering into force, etc."
      },
      "domain": [
        "http://data.europa.eu/2qy/rrmv#TemporalEntitySpec"
      ],
      "range": [
        "http://data.europa.eu/2qy/rrmv#TemporalFunction"
      ],
      "generalization": []
    },
    {
      "@id": "http://data.europa.eu/2qy/rrmv#hasType",
      "@type": "http://www.w3.org/2002/07/owl#ObjectProperty",
      "label": {
        "en": "has type"
      },
      "definition": {
        "en": "indicates the kind of the resource"
      },
      "domain": [
        "http://data.europa.eu/2qy/rrmv#Role"
      ],
