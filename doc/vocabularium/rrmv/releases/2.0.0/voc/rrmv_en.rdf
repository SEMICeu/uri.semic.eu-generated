    <rdfs:label xml:lang="en">has function</rdfs:label>
    <rdfs:comment xml:lang="en">The function played by the TemporalEntitySpecification, such as a deadline or a validity period.</rdfs:comment>
    <skos:scopeNote xml:lang="en">For instance as deadline, moment of entering into force, etc.</skos:scopeNote>
    <rdfs:domain rdf:resource="http://data.europa.eu/2qy/rrmv#TemporalEntitySpec"/>
    <rdfs:range rdf:resource="http://data.europa.eu/2qy/rrmv#TemporalFunction"/>
  </owl:ObjectProperty>
