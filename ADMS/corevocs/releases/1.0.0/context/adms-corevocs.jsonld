{
  "@context": {
    "Agent": "http://xmlns.com/foaf/0.1/Agent",
    "Code": "http://www.w3.org/2004/02/skos/core#Concept",
    "Date": "http://www.w3.org/2001/XMLSchema#date",
    "Identifier": "http://www.w3.org/ns/adms#Identifier",
    "IdentifierScheme": "http://data.europa.eu/adms/IdentifierScheme",
    "Literal": "http://www.w3.org/2000/01/rdf-schema#Literal",
    "Text": "http://www.w3.org/1999/02/22-rdf-syntax-ns#langString",
    "dateOfIssue": {
      "@container": "@set",
      "@id": "http://purl.org/dc/terms/issued",
      "@type": "http://www.w3.org/2001/XMLSchema#date"
    },
    "issuedBy": {
      "@container": "@set",
      "@id": "http://purl.org/dc/terms/creator",
      "@type": "@id"
    },
    "name": {
      "@container": "@set",
      "@id": "http://purl.org/dc/terms/title",
      "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"
    },
    "notation": {
      "@container": "@set",
      "@id": "http://www.w3.org/2004/02/skos/core#notation"
    },
    "schemeAgency": {
      "@container": "@set",
      "@id": "http://www.w3.org/ns/adms#schemeAgency"
    },
    "schemeName": {
      "@container": "@set",
      "@id": "http://www.w3.org/2000/01/rdf-schema#label",
      "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"
    },
    "schemeURI": {
      "@container": "@set",
      "@id": "http://purl.org/dc/terms/conformsTo",
      "@type": "@id"
    },
    "type": {
      "@container": "@set",
      "@id": "http://purl.org/dc/terms/type",
      "@type": "@id"
    }
  }
}
