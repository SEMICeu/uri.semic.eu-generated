  "classes": [
    {
      "@id": "http://www.w3.org/ns/adms#Identifier",
      "@type": "http://www.w3.org/2002/07/owl#Class",
      "label": {
        "en": "Identifier"
      },
      "definition": {
        "en": "A structured reference that identifies an entity."
      },
      "usage": {
        "en": "The Identifier class is based on the <a href=\"https://www.gs1.org/standards/edi/gs1-un-cefact-xml/2012\">UN/CEFACT</a> class of the same name and is defined under the ADMS namespace."
      },
      "parents": []
    }
  ],
  "externals": [],
  "properties": [
    {
      "@id": "http://www.w3.org/ns/adms#schemeAgency",
      "@type": "http://www.w3.org/2002/07/owl#DatatypeProperty",
      "label": {
        "en": "scheme agency"
      },
      "definition": {
        "en": "The name of the agency that issued the identifier."
      },
      "usage": {
        "en": "use dcterms:creator to link to a class describing the agency that manages the identifier scheme or adms:schemaAgency to provide the name as a literal."
      },
      "domain": [
        "http://www.w3.org/ns/adms#Identifier"
      ],
      "range": [
        "http://www.w3.org/2000/01/rdf-schema#Literal"
      ],
      "generalization": []
    }
  ],
