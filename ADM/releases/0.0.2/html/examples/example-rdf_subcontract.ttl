@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix locn: <http://www.w3.org/ns/locn#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix adm: <https://w3id.org/adm/model/> .
@prefix adms: <http://www.w3.org/ns/adms#> .
@prefix cv: <http://data.europa.eu/m8g/> .
@prefix epo: <http://data.europa.eu/a4g/ontology#> .
@prefix ex: <http://example.com/> .
@prefix frapo: <http://purl.org/cerif/frapo/> .
@prefix legal: <http://www.w3.org/ns/legal#> .
@prefix person: <http://www.w3.org/ns/person#> .

ex:subcontract1 adms:identifier ex:identifier9 ;
	dcterms:isPartOf ex:contract1 ;
	adm:hasSubcontractor ex:subcontractor1 ;
	adm:amount [
		epo:hasCurrency <http://publications.europa.eu/resource/authority/currency/EUR> ;
		epo:hasAmountValue 12789.26 ;
		rdf:type epo:MonetaryValue ;
	] ;
	a adm:Subcontract .

ex:identifier9 skos:notation "SC-001" ;
	a adms:Identifier .

ex:subcontractor1 epo:playedBy ex:legalEntity2 ;
	a epo:Subcontractor .

ex:legalEntity2 adms:identifier ex:identifier10 ;
	a legal:LegalEntity .

ex:identifier10 skos:notation "VE-124-88" ;
	a adms:Identifier .

