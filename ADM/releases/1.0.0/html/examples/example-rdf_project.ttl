@prefix adm: <https://w3id.org/adm/model/> .
@prefix adms: <http://www.w3.org/ns/adms#> .
@prefix cv: <http://data.europa.eu/m8g/> .
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix ex: <http://example.com/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix locn: <http://www.w3.org/ns/locn#> .
@prefix person: <http://www.w3.org/ns/person#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:project1 
	adms:identifier ex:identifier1 ;
	adms:status ex:status1 ;
	rdfs:label "Project name"@en ;
	ex:hasBeneficiary ex:beneficiary1 ;
	dbo:projectStartDate "2012-01-01"^^xsd:date ;
	dbo:projectEndDate "2012-06-01"^^xsd:date ;
	adm:ECFinancialAssistance [
		adm:currency <http://publications.europa.eu/resource/authority/currency/EUR>;
		adm:value "8733000"^^xsd:decimal ;
		a adm:Amount .
	];
	adm:otherContributions [
		adm:currency <http://publications.europa.eu/resource/authority/currency/EUR>;
		adm:value "4125000"^^xsd:decimal;
		a adm:Amount .
	];
	adm:income [
		adm:currency <http://publications.europa.eu/resource/authority/currency/EUR>;
		adm:value "12733.85"^^xsd:decimal;
		a adm:Amount .
	];	
	adm:totalCost [
		adm:currency <http://publications.europa.eu/resource/authority/currency/EUR>;
		adm:value "12870733.85"^^xsd:decimal;
		a adm:Amount .
	];
	adm:thematicObjective <https://w3id.org/adm/codelist/thematicObjective/10>;
	a dbo:Project .

ex:status1 skos:prefLabel "Open"@en ;
	a skos:Concept .

ex:beneficiary1 adms:identifier ex:identifier2 ;
	a ex:Beneficiary .

ex:identifier1 skos:notation "Project 0124" ;
	a adms:Identifier .

ex:identifier2 skos:notation "5800012" ;
	a adms:Identifier .