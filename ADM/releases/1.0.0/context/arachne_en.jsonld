{
  "@context": {
    "Amount": "http://example.com/Amount",
    "Beneficiary": "http://example.com/Beneficiary",
    "Code": "http://www.w3.org/2004/02/skos/core#Concept",
    "Contract": "http://data.europa.eu/a4g/ontology#Contract",
    "Date": "http://www.w3.org/2001/XMLSchema#date",
    "Document": "http://data.europa.eu/a4g/ontology#Document",
    "GenericDate": "http://data.europa.eu/m8g/GenericDate",
    "Identifier": "http://www.w3.org/ns/adms#Identifier",
    "Integer": "http://www.w3.org/2001/XMLSchema#integer",
    "KeyExpert": "http://example.com/KeyExpert",
    "LegalEntity": "http://www.w3.org/ns/legal#LegalEntity",
    "Literal": "http://www.w3.org/2000/01/rdf-schema#Literal",
    "Person": "http://www.w3.org/ns/person#Person",
    "Project": "http://dbpedia.org/ontology/Project",
    "Subcontract": "http://example.com/Subcontract",
    "Text": "http://www.w3.org/1999/02/22-rdf-syntax-ns#langString",
    "belongsTo": {
      "@id": "http://example.com/belongsTo",
      "@type": "@id"
    },
    "dateOfBirth": {
      "@container": "@set",
      "@id": "http://data.europa.eu/m8g/birthDate",
      "@type": "http://data.europa.eu/m8g/GenericDate"
    },
    "endDate": {
      "@id": "http://dbpedia.org/ontology/projectEndDate",
      "@type": "http://www.w3.org/2001/XMLSchema#date"
    },
    "familyName": {
      "@container": "@set",
      "@id": "http://xmlns.com/foaf/0.1/familyName",
      "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"
    },
    "givenName": {
      "@container": "@set",
      "@id": "http://xmlns.com/foaf/0.1/givenName",
      "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"
    },
    "hasBeneficiary": {
      "@id": "http://example.com/hasBeneficiary",
      "@type": "@id"
    },
    "hasKeyExpert": {
      "@container": "@set",
      "@id": "http://example.com/hasKeyExpert",
      "@type": "@id"
    },
    "hasUltimateOwner": {
      "@id": "http://example.com/hasUltimateOwner",
      "@type": "@id"
    },
    "identifier": {
      "@container": "@set",
      "@id": "http://www.w3.org/ns/adms#identifier",
      "@type": "@id"
    },
    "isPartOf": {
      "@id": "http://purl.org/dc/terms/isPartOf",
      "@type": "@id"
    },
    "legalIdentifier": {
      "@container": "@set",
      "@id": "http://www.w3.org/ns/legal#legalIdentifier",
      "@type": "@id"
    },
    "name": {
      "@id": "http://www.w3.org/2000/01/rdf-schema#label",
      "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"
    },
    "notation": {
      "@id": "http://www.w3.org/2004/02/skos/core#notation"
    },
    "numberOfEmployees": {
      "@id": "http://example.com/numberOfEmployees",
      "@type": "http://www.w3.org/2001/XMLSchema#integer"
    },
    "startDate": {
      "@id": "http://dbpedia.org/ontology/projectStartDate",
      "@type": "http://www.w3.org/2001/XMLSchema#date"
    },
    "status": {
      "@id": "https://www.w3.org/ns/adms#status",
      "@type": "@id"
    },
    "turnover": {
      "@id": "http://example.com/turnover",
      "@type": "@id"
    }
  }
}
