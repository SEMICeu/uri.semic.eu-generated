<http://example.com/polads/1> dct:subject <http://example.com/subject/environment> ;
	dct:description "This advertisement promotes sustainable energy initiatives across Europe."@en ;
	dct:type <http://example.com/theme/video> ;
	dct:language <http://publications.europa.eu/resource/authority/language/ENG> ;
	dct:created "2025-01-10"^^xsd:date ;
	time:hasBeginning [
		time:inXSDDate "2025-02-01"^^xsd:date ;
	] ;
	time:hasEnd [
		time:inXSDDate "2025-02-28"^^xsd:date ;
	] ;
	ttpa:intendedStartPublicationDate "2025-02-01"^^xsd:date ;
	ttpa:intendedEndPublicationDate "2025-02-28"^^xsd:date ;
	ttpa:hasInitiative <http://example.com/initiative/1> ;
	ttpa:hasElection <http://example.com/election/1> ;
	a ttpa:PoliticalAdvertisement .

<http://example.com/initiative/1> dct:title "European Green Deal Implementation"@en ;
	dct:type <http://example.com/initiativetype/legislative> ;
	a ttpa:Initiative .

