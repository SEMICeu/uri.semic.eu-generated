          <xs:documentation xml:lang="en">Indicates whether targeting techniques are used for this advertisement.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="userRightsSupportUrl" ref="AnyUriType" maxOccurs="unbounded" minOccurs="0">
