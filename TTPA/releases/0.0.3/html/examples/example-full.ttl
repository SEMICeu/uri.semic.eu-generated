@prefix adms: <http://www.w3.org/ns/adms#> .
@prefix cv: <http://data.europa.eu/m8g/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dpv: <https://w3id.org/dpv#> .
@prefix epo: <http://data.europa.eu/a4g/ontology#> .
@prefix ex: <http://example.com/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix frapo: <http://purl.org/cerif/frapo/> .
@prefix legal: <http://www.w3.org/ns/legal#> .
@prefix locn: <http://www.w3.org/ns/locn#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix ttpa: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.com/transparencyNotice/1> ttpa:hasFunding <http://example.com/funding/1> ;
	a ttpa:TransparencyNotice .

<http://example.com/entity/1> legal:legalName "Green Future Association Ltd."@en ;
	cv:email "contact@sponsor.org" ;
	cv:registeredAddress <http://example.com/address/1> ;
	locn:address <http://example.com/address/2> ;
	a legal:LegalEntity, foaf:Agent .

<http://example.com/address/1> a locn:Address .

<http://example.com/address/2> a locn:Address .

<http://example.com/funding/1> ttpa:calculationMethodology "Aggregated from invoices and declared contributions over the campaign period."@en ;
	ttpa:totalAmount [
		rdf:type epo:MonetaryValue ;
		epo:hasCurrency <http://publications.europa.eu/resource/authority/currency/EUR> ;
		epo:hasAmountValue "15000.00"^^xsd:decimal ;
	] ;
	ttpa:fundingOrigin <http://example.com/originFunding/EU_AND_NON_EU> ;
	ttpa:hasPoliticalAdvertisement <http://example.com/politicalAdvertisement/1> ;
	a frapo:Funding .

<http://example.com/politicalAdvertisement/1> dct:subject <http://example.com/subject/environment> ;
	dct:description "This advertisement promotes sustainable energy initiatives across Europe."@en ;
	dct:type <http://example.com/theme/video> ;
	dct:language <http://publications.europa.eu/resource/authority/language/ENG> ;
	dct:created "2025-01-10"^^xsd:date ;
	dcat:startDate "2025-02-01"^^xsd:date ;
	dcat:endDate "2025-02-28"^^xsd:date ;
	ttpa:intendedStartPublicationDate "2025-02-01"^^xsd:date ;
	ttpa:intendedEndPublicationDate "2025-02-28"^^xsd:date ;
	ttpa:hasInitiative <http://example.com/initiative/1> ;
	ttpa:hasElection <http://example.com/election/1> ;
	ttpa:hasSponsor <http://example.com/entity/1> ;
	ttpa:hasFunding <http://example.com/funding/1> ;
	a ttpa:PoliticalAdvertisement .

<http://example.com/initiative/1> dct:title "European Green Deal Implementation"@en ;
	dct:type <http://example.com/initiativetype/legislative> ;
	a ttpa:Initiative .

<http://example.com/election/1> dct:title "European Climate Election 2025"@en ;
	foaf:homepage <https://www.example.org/votes/european-climate-2025> ;
	a ttpa:ElectionEvent .

<http://example.com/technique/1> ttpa:targetingParameters <http://example.com/parameters/1> ;
	dpv:hasPersonalData <http://example.com/personaldata/email>, <http://example.com/personaldata/location> ;
	ttpa:hasControllingEntity <http://example.com/entity/1> ;
	ttpa:targetingGoals "Increase awareness and engagement for sustainable energy initiatives."@en ;
	dpv:hasPolicy "https://www.sponsor.org/policy"^^xsd:anyURI ;
	ttpa:otherRelevantInformation "Includes A/B testing of different creative formats."@en ;
	ttpa:numberOfViews 200000 ;
	ttpa:numberOfLikes 3500 ;
	ttpa:consentNotice "https://www.sponsor.org/consent"^^xsd:anyURI ;
	ttpa:userRightsSupportUrl "https://www.sponsor.org/support"^^xsd:anyURI ;
	a ttpa:Technique, ttpa:TargetingTechnique .

<http://example.com/entity/2> legal:legalName "AdTech Solutions Ltd."@en ;
	cv:email "control@adtech.com" ;
	a legal:LegalEntity .

