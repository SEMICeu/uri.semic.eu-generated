@prefix adms: <http://www.w3.org/ns/adms#> .
@prefix cv: <http://data.europa.eu/m8g/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dpv: <http://www.w3.org/ns/dpv#> .
@prefix ex: <http://example.com/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix frapo: <http://purl.org/cerif/frapo/> .
@prefix legal: <http://www.w3.org/ns/legal#> .
@prefix locn: <http://www.w3.org/ns/locn#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix ttpa: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://polads.eu/en/A94HT> ttpa:hasFunding <http://example.com/funding/1> ;
	a ttpa:TransparencyNotice .

<http://example.com/address/1> locn:adminUnitL1 "Denmark"@en ;
	locn:postName "København k"@da ;
	a locn:Address .

<http://example.com/funding/1> cv:currency <http://publications.europa.eu/resource/authority/currency/DKK> ;
	cv:hasValue "20000.00"^^xsd:decimal ;
	ttpa:nature <http://example.com/natureFunding/PRIVATE> ;
	ttpa:hasPoliticalAdvertisement <http://example.com/politicalAdvertisement/1> ;
	a frapo:Funding .

<http://example.com/politicalAdvertisement/1> dct:description "Folketingsvalg 2026, Peter Skaarup, Digita"@da ;
	dct:created "2026-02-19"^^xsd:date ;
	dcat:endDate "2026-11-01"^^xsd:date ;
	dcat:startDate "2026-02-19"^^xsd:date ;
	ttpa:hasSponsor <http://example.com/entity/1> ;
	a ttpa:PoliticalAdvertisement .

<http://example.com/entity/1> legal:legalName "Danmarksdemokraterne"@en ;
	cv:registeredAddress <http://example.com/address/1> ;
	a legal:LegalEntity, foaf:Agent .