          "sh:class": "http://purl.org/linked-data/cube#AttributeProperty",
          "sh:description": {
            "en": "a component used to qualify and interpret observed values, e.g. units of measure, any scaling factors and metadata such as the status of the observation (e.g. estimated, provisional).\r\nAttribute is a conceptual entity that applies to all distribution formats, e.g. in case a dataset is provided both in SDMX and in DataCube."
          },
          "sh:name": {
            "en": "attribute"
          },
          "sh:path": "http://data.europa.eu/s1n/attribute"
        },
