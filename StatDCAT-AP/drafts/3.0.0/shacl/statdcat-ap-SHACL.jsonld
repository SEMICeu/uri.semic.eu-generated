          "rdfs:seeAlso": "https://semiceu.github.io/StatDCAT-AP/drafts/3.0.0#Resource.unitofmeasurement",
          "sh:class": "http://www.w3.org/2004/02/skos/core#Concept",
          "sh:description": {
            "en": "a unit of measurement of the observations in the dataset, for example Euro, square kilometre,\r\npurchasing power standard (PPS), full-time equivalent, percentage. \r\nUnit of measurement is a conceptual entity that applies to all distribution formats,\r\ne.g. in the case when a dataset is provided both in SDMX and in Data Cube."
          },
          "sh:name": {
            "en": "unit of measurement"
          },
          "sh:path": "http://data.europa.eu/s1n/statUnitMeasure"
        },
